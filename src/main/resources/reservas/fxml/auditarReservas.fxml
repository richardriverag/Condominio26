<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER"
      maxHeight="1.7976931348623157E308"
      maxWidth="1.7976931348623157E308"
      prefHeight="600.0"
      prefWidth="900.0"
      spacing="16.0"
      styleClass="module-content"
      stylesheets="@../css/reservasStyles.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1">

   <padding>
      <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
   </padding>

   <children>
      <!-- ENCABEZADO DEL MÓDULO -->
      <VBox alignment="CENTER" maxWidth="960.0" spacing="4.0">
         <children>
            <Label styleClass="module-title" text="Auditoría de Reservas" />
            <Label styleClass="module-subtitle" text="Supervisa, filtra y gestiona todas las reservas realizadas por los residentes del condominio." />
         </children>
         <VBox.margin>
            <Insets bottom="8.0" />
         </VBox.margin>
      </VBox>

      <!-- PANEL PRINCIPAL -->
      <VBox fx:id="panelPrincipal" maxWidth="960.0" spacing="16.0" VBox.vgrow="ALWAYS">
         <children>
            <!-- Primer bloque: Filtros -->
            <VBox maxWidth="Infinity" spacing="12.0" styleClass="module-card">
               <padding>
                  <Insets bottom="16.0" left="24.0" right="24.0" top="16.0"/>
               </padding>
               <children>
                  <!-- Barra de Filtros -->
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <Label text="Residente:" styleClass="form-label"/>
                        <TextField fx:id="txtBusquedaResidente" prefWidth="160.0" promptText="Nombre..." styleClass="text-field" />
                        
                        <Label text="Espacio:" styleClass="form-label"/>
                        <ChoiceBox fx:id="cbFiltroEspacio" prefWidth="140.0" styleClass="choice-box" />
                        
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <Label text="Desde:" styleClass="form-label"/>
                        <DatePicker fx:id="dpFechaInicio" prefWidth="120.0" styleClass="date-picker" promptText="Inicio" showWeekNumbers="false" />
                        
                        <Label text="Hasta:" styleClass="form-label"/>
                        <DatePicker fx:id="dpFechaFin" prefWidth="120.0" styleClass="date-picker" promptText="Fin" showWeekNumbers="false" />
                        
                        <Button mnemonicParsing="false" onAction="#limpiarFiltros" text="X" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 5 10 5 10; -fx-background-radius: 4; -fx-cursor: hand;" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <!-- Segundo bloque: Tabla -->
            <VBox maxWidth="Infinity" spacing="16.0" styleClass="module-card" VBox.vgrow="ALWAYS">
               <padding>
                  <Insets bottom="20.0" left="24.0" right="24.0" top="20.0"/>
               </padding>
               <children>
                  <!-- Cabecera con Título -->
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="module-section-title" style="-fx-font-size: 18px;" text="Lista General de Reservas" />
                     </children>
                  </HBox>
            
            <!-- Tabla de Reservas -->
            <TableView fx:id="tablaReservas" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">
               <VBox.margin>
                  <Insets left="48.0" right="48.0" />
               </VBox.margin>
              <columns>
                  <TableColumn fx:id="colResidente" prefWidth="186.0" text="Nombre del Residente" />
                  <TableColumn fx:id="colEspacio" prefWidth="166.0" text="Espacio reservado" />
                  <TableColumn fx:id="colFecha" prefWidth="106.0" text="Fecha" />
                  <TableColumn fx:id="colHoraInicio" prefWidth="96.0" text="Hora Inicio" />
                  <TableColumn fx:id="colHoraFin" prefWidth="96.0" text="Hora Fin" />
                  <TableColumn fx:id="colEstado" prefWidth="126.0" text="Estado" />
                  <TableColumn fx:id="colOpciones" prefWidth="186.0" text="Opciones" style="-fx-alignment: CENTER;" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
         </children>
      </VBox>

      <!-- PANEL SECUNDARIO (AGREGAR OBSERVACIÓN) -->
      <VBox fx:id="panelObservacion" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="960.0" spacing="16.0" VBox.vgrow="ALWAYS" managed="false" visible="false">
         <children>
            <VBox maxWidth="650.0" spacing="16.0" styleClass="module-card">
               <padding>
                  <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
               </padding>
               <children>
                  <Label styleClass="module-section-title" style="-fx-font-size: 18px;" text="Comentario de la reserva (Auditoría)" />
                  <TextArea fx:id="txtObservacion" prefHeight="150.0" promptText="Aquí puedes añadir tus observaciones respecto a esta reserva." wrapText="true" />
                  
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <!-- MULTA -->
                        <Button fx:id="btnAnadirMulta" mnemonicParsing="false" onAction="#toggleMulta" styleClass="secondary-button" text="Añadir Multa" />
                        <ChoiceBox fx:id="cbMotivoMulta" visible="false" managed="false" prefWidth="200.0" styleClass="choice-box" />
                        
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <!-- BOTONES ACCIÓN -->
                        <Button mnemonicParsing="false" onAction="#cancelarObservacion" styleClass="secondary-button" text="Cancelar" />
                        <Button mnemonicParsing="false" onAction="#enviarObservacion" style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 9 18; -fx-cursor: hand;" text="Registrar auditoría" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</VBox>
