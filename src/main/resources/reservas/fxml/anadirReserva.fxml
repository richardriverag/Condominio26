<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" maxHeight="Infinity" maxWidth="Infinity" prefHeight="600.0" prefWidth="900.0" spacing="16.0" styleClass="module-content" stylesheets="@../css/reservasStyles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fis.dsw.sgc.reservas.controller.AnadirReservaController">

   <padding>
      <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
   </padding>

   <children>
      <Label styleClass="module-title" text="Reserva de Espacio del Condominio" />
      <Label styleClass="module-subtitle" text="Seleccione el tipo de espacio para visualizar los horarios disponibles y realizar su reserva." />
      
      <VBox fx:id="panelPrincipal" maxHeight="Infinity" maxWidth="960.0" spacing="16.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox maxWidth="Infinity" spacing="12.0" styleClass="module-card">
               <padding>
                  <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="16.0">
                     <children>
                        <VBox spacing="4.0">
                           <children>
                              <Label styleClass="form-label" text="Espacio" />
                              <ChoiceBox fx:id="cbTipoEspacio" prefWidth="180.0" styleClass="choice-box" />
                           </children>
                        </VBox>
                        
                        <VBox spacing="4.0">
                           <children>
                              <Label styleClass="form-label" text="Fecha" />
                              <TextField fx:id="txtFecha" editable="false" prefWidth="120.0" promptText="En tabla" styleClass="text-field" />
                           </children>
                        </VBox>
                        
                        <VBox spacing="4.0">
                           <children>
                              <Label styleClass="form-label" text="Inicio" />
                              <TextField fx:id="txtHoraInicio" editable="false" prefWidth="110.0" promptText="--:--" styleClass="text-field" />
                           </children>
                        </VBox>
                        
                        <VBox spacing="4.0">
                           <children>
                              <Label styleClass="form-label" text="Fin" />
                              <TextField fx:id="txtHoraFin" editable="false" prefWidth="110.0" promptText="--:--" styleClass="text-field" />
                           </children>
                        </VBox>
                        
                        <Region HBox.hgrow="ALWAYS" />
                        <VBox alignment="BOTTOM_CENTER" spacing="4.0">
                           <children>
                              <Button fx:id="btnReservar" mnemonicParsing="false" onAction="#reservar" styleClass="primary-button" text="Reservar Espacio" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox maxWidth="Infinity" spacing="8.0" styleClass="table-card">
               <padding>
                  <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="16.0">
                     <children>
                        <Label styleClass="module-section-title" text="Espacios Disponibles para Reservar" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="8.0">
                           <children>
                              <Button fx:id="btnSemanaAnterior" mnemonicParsing="false" onAction="#anteriorSemana" styleClass="secondary-button" text="&lt;" />
                              <Label fx:id="lblSemana" styleClass="form-label" style="-fx-font-size: 14px; -fx-min-width: 120px; -fx-alignment: CENTER;" text="Semana Actual" />
                              <Button fx:id="btnSemanaSiguiente" mnemonicParsing="false" onAction="#siguienteSemana" styleClass="secondary-button" text="&gt;" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
                  <TableView fx:id="tablaHorarios" prefHeight="300.0" maxWidth="Infinity">
                     <columns>
                        <TableColumn fx:id="colHora" prefWidth="100.0" text="Hora" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colLunes" prefWidth="100.0" text="Lunes" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colMartes" prefWidth="100.0" text="Martes" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colMiercoles" prefWidth="100.0" text="Miércoles" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colJueves" prefWidth="100.0" text="Jueves" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colViernes" prefWidth="100.0" text="Viernes" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colSabado" prefWidth="100.0" text="Sábado" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colDomingo" prefWidth="100.0" text="Domingo" style="-fx-alignment: CENTER;" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </VBox>
      
      <!-- PANEL SECUNDARIO (ERROR DE HORARIO) -->
      <VBox fx:id="panelError" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="960.0" spacing="16.0" VBox.vgrow="ALWAYS" managed="false" visible="false">
         <children>
            <VBox maxWidth="500.0" spacing="16.0" styleClass="module-card">
               <padding>
                  <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
               </padding>
               <children>
                  <Label styleClass="module-section-title" style="-fx-font-size: 18px; -fx-text-fill: #c62828;" text="Horario no disponible" />
                  <Label text="No puedes reservar en esta hora porque estás chocando con un horario donde ya se está ocupando el espacio." wrapText="true" style="-fx-font-size: 14px;" />
                  
                  <HBox alignment="CENTER_RIGHT" spacing="12.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#cerrarPanelError" style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 9 18; -fx-cursor: hand;" text="Entendido" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</VBox>
