<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER"
      maxHeight="Infinity"
      maxWidth="Infinity"
      prefHeight="800.0"
      prefWidth="900.0"
      spacing="16.0"
      styleClass="module-content"
      stylesheets="@../css/checkInStyles.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fis.dsw.sgc.check_in.controller.RegistrarEntradaExternaController">

    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/>
    </padding>

    <children>
        <VBox alignment="CENTER" maxWidth="960.0" spacing="4.0">
            <children>
                <Label styleClass="module-title" text="Registrar Entrada Externa"/>
                <Label styleClass="module-subtitle"
                       text="Registre el ingreso de visitantes, proveedores o personal externo al condominio."/>
            </children>
        </VBox>

        <VBox maxWidth="960.0" spacing="14.0" styleClass="module-card">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
            </padding>
            <children>
                <GridPane hgap="12.0" vgap="14.0" maxWidth="Infinity">
                    <columnConstraints>
                        <ColumnConstraints minWidth="150.0" prefWidth="160.0"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" prefWidth="360.0"/>
                    </columnConstraints>
                    <children>
                        <Label styleClass="form-label" text="Identificación" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtIdentificacionVisitante" promptText="Cédula / pasaporte"
                                   maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label styleClass="form-label" text="Nombre del visitante" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtNombreVisitante" promptText="Nombre completo"
                                   maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label styleClass="form-label" text="Teléfono (opcional)" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtTelefono" promptText="09XXXXXXXX"
                                   maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label styleClass="form-label" text="Residente relacionado" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtDestino" promptText="Ej. Depto. 205 - Carla Muñoz"
                                   maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label styleClass="form-label" text="Información Adicional" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <TextField fx:id="txtInfoAdicional" promptText="Ej. Entrega de paquetes (opcional)"
                                   maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    </children>
                </GridPane>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label styleClass="form-label" text="Uso de Parqueadero:"/>
                        <CheckBox fx:id="chkRequiereParqueadero" onAction="#toggleParqueadero"
                                  text="El visitante ingresa con vehículo y requiere espacio"/>
                    </children>
                </HBox>

                <VBox fx:id="panelParqueadero" managed="false" spacing="12.0" visible="false"
                      style="-fx-background-color: #f9fafb; -fx-background-radius: 6; -fx-padding: 16;">
                    <children>
                        <Label styleClass="form-label" text="Datos del vehículo"/>
                        <HBox spacing="16.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="form-label" text="Placa"/>
                                        <TextField fx:id="txtPlaca" promptText="ABC-1234" maxWidth="Infinity"/>
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="form-label" text="Parqueadero de visita"/>
                                        <ChoiceBox fx:id="cbParqueadero" maxWidth="Infinity"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Label styleClass="form-hint" text="Al registrar, se notificará automáticamente al residente relacionado."/>
                <Label fx:id="lblMensaje" styleClass="message-label"/>

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Button fx:id="btnLimpiar" mnemonicParsing="false" onAction="#limpiarFormulario"
                                styleClass="secondary-button" text="Limpiar"/>
                        <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#registrarEntradaExterna"
                                styleClass="primary-button" text="Registrar Entrada Externa"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox maxWidth="960.0" spacing="8.0" styleClass="table-card" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
            </padding>
            <children>
                <Label styleClass="module-section-title" text="Ingresos Externos Recientes"/>
                <TableView fx:id="tablaIngresos" prefHeight="400.0" minHeight="300.0" maxWidth="Infinity" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colHora" prefWidth="90.0" text="Hora"/>
                        <TableColumn fx:id="colNombre" prefWidth="180.0" text="Visitante"/>
                        <TableColumn fx:id="colDestino" prefWidth="180.0" text="Residente"/>
                        <TableColumn fx:id="colInfoAdicional" prefWidth="170.0" text="Info. Adicional"/>
                        <TableColumn fx:id="colParqueadero" prefWidth="140.0" text="Parqueadero" style="-fx-alignment: CENTER;"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>