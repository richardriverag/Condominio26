<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>


<StackPane maxHeight="Infinity"
           maxWidth="Infinity"
           prefHeight="800.0"
           prefWidth="900.0"
           stylesheets="@../css/checkInStyles.css"
           xmlns="http://javafx.com/javafx/26"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="fis.dsw.sgc.check_in.controller.GestionarHistorialIngresosController">

    <children>
        <VBox fx:id="panelPrincipal" alignment="TOP_CENTER" spacing="16.0" styleClass="module-content">
            <padding>
                <Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/>
            </padding>
            <children>
                <VBox alignment="CENTER" maxWidth="960.0" spacing="4.0">
                    <children>
                        <Label styleClass="module-title" text="Gestionar Historial de Ingresos"/>
                        <Label styleClass="module-subtitle"
                               text="Consulte y revise los ingresos de residentes, visitantes y parqueaderos del condominio."/>
                    </children>
                </VBox>

                <VBox maxWidth="960.0" spacing="12.0" styleClass="module-card">
                    <padding>
                        <Insets bottom="16.0" left="24.0" right="24.0" top="16.0"/>
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label styleClass="form-label" text="Persona:"/>
                                <TextField fx:id="txtBusquedaPersona" prefWidth="160.0" promptText="Nombre..."/>

                                <Label styleClass="form-label" text="Tipo:"/>
                                <ChoiceBox fx:id="cbTipoIngreso" prefWidth="140.0"/>

                                <Label styleClass="form-label" text="Placa:"/>
                                <TextField fx:id="txtPlaca" prefWidth="110.0" promptText="ABC-1234"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label styleClass="form-label" text="Desde:"/>
                                <DatePicker fx:id="dpFechaInicio" prefWidth="130.0" promptText="Inicio"/>

                                <Label styleClass="form-label" text="Hasta:"/>
                                <DatePicker fx:id="dpFechaFin" prefWidth="130.0" promptText="Fin"/>

                                <Button fx:id="btnBuscar" mnemonicParsing="false" onAction="#buscarHistorial"
                                        styleClass="primary-button" text="Buscar"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox maxWidth="960.0" spacing="12.0" styleClass="module-card" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0"/>
                    </padding>
                    <children>
                        <Label styleClass="module-section-title" text="Registros del Historial"/>
                        <Label fx:id="lblMensaje" styleClass="message-label"/>
                        
                        <TableView fx:id="tablaHistorial" VBox.vgrow="ALWAYS" maxHeight="Infinity">
                            <columns>
                                <TableColumn fx:id="colFecha" prefWidth="110.0" text="Fecha"/>
                                <TableColumn fx:id="colHora" prefWidth="100.0" text="Hora"/>
                                <TableColumn fx:id="colTipo" prefWidth="140.0" text="Tipo" style="-fx-alignment: CENTER;"/>
                                <TableColumn fx:id="colPersona" prefWidth="350.0" text="Persona"/>
                                <TableColumn fx:id="colDetalle" prefWidth="150.0" text="Detalle" style="-fx-alignment: CENTER;"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#generarReporte"
                                        styleClass="secondary-button" text="Generar Reporte"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>

        <VBox fx:id="panelDetalle" alignment="CENTER" visible="false" style="-fx-background-color: rgba(0, 0, 0, 0.4);">
            <children>
                <VBox maxWidth="560.0" spacing="16.0" styleClass="module-card">
                    <padding>
                        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/>
                    </padding>
                    <children>
                        <Label styleClass="module-section-title" style="-fx-font-size: 20px;" text="Detalle del Ingreso"/>
                        
                        <Label fx:id="lblDetalleTipo" styleClass="message-label" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblDetallePersona" styleClass="message-label"/>
                        <Label fx:id="lblDetalleFechaHora" styleClass="message-label"/>
                        <Label fx:id="lblDetalleMotivo" styleClass="message-label" wrapText="true"/>
                        <Label fx:id="lblDetallePlaca" styleClass="message-label"/>
                        <Label fx:id="lblDetalleInfoAdicional" styleClass="message-label" wrapText="true"/>

                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <VBox.margin>
                                <Insets top="16.0"/>
                            </VBox.margin>
                            <children>
                                <Button mnemonicParsing="false" onAction="#cerrarDetalle"
                                        styleClass="confirm-button" text="Cerrar Detalles"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>