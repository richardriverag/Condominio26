<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER"
      maxHeight="1.7976931348623157E308"
      maxWidth="1.7976931348623157E308"
      prefHeight="600.0"
      prefWidth="900.0"
      spacing="16.0"
      styleClass="module-content"
      stylesheets="@../css/checkInStyles.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fis.dsw.sgc.check_in.controller.GestionarHistorialIngresosController">

    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/>
    </padding>

    <children>
        <VBox alignment="CENTER" maxWidth="960.0" spacing="4.0">
            <children>
                <Label styleClass="module-title" text="Gestionar Historial de Ingresos"/>
                <Label styleClass="module-subtitle"
                       text="Consulte y revise los ingresos de residentes, visitantes y parqueaderos del condominio."/>
            </children>
        </VBox>

        <!-- PANEL PRINCIPAL -->
        <VBox fx:id="panelPrincipal" maxWidth="960.0" spacing="16.0" VBox.vgrow="ALWAYS">
            <children>
                <!-- Filtros -->
                <VBox maxWidth="Infinity" spacing="12.0" styleClass="module-card">
                    <padding>
                        <Insets bottom="16.0" left="24.0" right="24.0" top="16.0"/>
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label styleClass="form-label" text="Persona:"/>
                                <TextField fx:id="txtBusquedaPersona" prefWidth="160.0" promptText="Nombre..."/>

                                <Label styleClass="form-label" text="Tipo:"/>
                                <ChoiceBox fx:id="cbTipoIngreso" prefWidth="140.0"/>

                                <Label styleClass="form-label" text="Placa:"/>
                                <TextField fx:id="txtPlaca" prefWidth="110.0" promptText="ABC-1234"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label styleClass="form-label" text="Desde:"/>
                                <DatePicker fx:id="dpFechaInicio" prefWidth="130.0" promptText="Inicio"/>

                                <Label styleClass="form-label" text="Hasta:"/>
                                <DatePicker fx:id="dpFechaFin" prefWidth="130.0" promptText="Fin"/>

                                <Button fx:id="btnBuscar" mnemonicParsing="false" onAction="#buscarHistorial"
                                        styleClass="primary-button" text="Buscar"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Tabla -->
                <VBox maxWidth="Infinity" spacing="12.0" styleClass="module-card" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0"/>
                    </padding>
                    <children>
                        <Label styleClass="module-section-title" text="Registros del Historial"/>
                        <Label fx:id="lblMensaje" styleClass="message-label"/>
                        <TableView fx:id="tablaHistorial" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">
                            <columns>
                                <TableColumn fx:id="colFecha" prefWidth="100.0" text="Fecha"/>
                                <TableColumn fx:id="colHora" prefWidth="80.0" text="Hora"/>
                                <TableColumn fx:id="colTipo" prefWidth="110.0" text="Tipo" style="-fx-alignment: CENTER;"/>
                                <TableColumn fx:id="colPersona" prefWidth="200.0" text="Persona"/>
                                <TableColumn fx:id="colMotivo" prefWidth="190.0" text="Motivo"/>
                                <TableColumn fx:id="colPlaca" prefWidth="100.0" text="Placa"/>
                                <TableColumn fx:id="colDetalle" prefWidth="110.0" text="Detalle" style="-fx-alignment: CENTER;"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>

        <!-- PANEL SECUNDARIO: DETALLE DE REGISTRO (solo lectura) -->
        <VBox fx:id="panelDetalle" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="960.0"
              spacing="16.0" VBox.vgrow="ALWAYS" managed="false" visible="false">
            <children>
                <VBox maxWidth="560.0" spacing="14.0" styleClass="module-card">
                    <padding>
                        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/>
                    </padding>
                    <children>
                        <Label styleClass="module-section-title" style="-fx-font-size: 18px;" text="Detalle del Ingreso"/>
                        <Label fx:id="lblDetalleTipo" styleClass="message-label"/>
                        <Label fx:id="lblDetallePersona" styleClass="message-label"/>
                        <Label fx:id="lblDetalleFechaHora" styleClass="message-label"/>
                        <Label fx:id="lblDetalleMotivo" styleClass="message-label" wrapText="true"/>
                        <Label fx:id="lblDetallePlaca" styleClass="message-label"/>

                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#cerrarDetalle"
                                        styleClass="confirm-button" text="Cerrar"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
