<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER"
      maxHeight="1.7976931348623157E308"
      maxWidth="1.7976931348623157E308"
      prefHeight="600.0"
      prefWidth="900.0"
      spacing="16.0"
      styleClass="module-content"
      stylesheets="@../css/checkInStyles.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fis.dsw.sgc.check_in.controller.RegistrarEntradaResidenteController">

    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/>
    </padding>

    <children>
        <VBox alignment="CENTER" maxWidth="960.0" spacing="4.0">
            <children>
                <Label styleClass="module-title" text="Registrar Entrada de Residente"/>
                <Label styleClass="module-subtitle"
                       text="Verifique la identidad del residente y registre su ingreso al condominio."/>
            </children>
        </VBox>

        <!-- FORMULARIO -->
        <VBox maxWidth="960.0" spacing="14.0" styleClass="module-card">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
            </padding>
            <children>
                <GridPane hgap="12.0" vgap="14.0" maxWidth="1.7976931348623157E308">
                    <columnConstraints>
                        <ColumnConstraints minWidth="150.0" prefWidth="160.0"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" prefWidth="360.0"/>
                    </columnConstraints>
                    <children>
                        <Label styleClass="form-label" text="Identificación del residente"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <HBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <children>
                                <TextField fx:id="txtIdentificacion" promptText="Cédula del residente"
                                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                                <Button fx:id="btnBuscar" mnemonicParsing="false" onAction="#buscarResidente"
                                        styleClass="secondary-button" text="Buscar"/>
                            </children>
                        </HBox>

                        <Label styleClass="form-label" text="Nombre" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtNombreResidente" editable="false" promptText="Se completa al buscar"
                                   maxWidth="1.7976931348623157E308"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label styleClass="form-label" text="Departamento / Unidad"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtDepartamento" editable="false" promptText="Se completa al buscar"
                                   maxWidth="1.7976931348623157E308"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label styleClass="form-label" text="Motivo (opcional)"
                               GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtMotivo" promptText="Ej. Regreso a casa"
                                   maxWidth="1.7976931348623157E308"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    </children>
                </GridPane>

                <Label fx:id="lblMensaje" styleClass="message-label"/>

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Button fx:id="btnLimpiar" mnemonicParsing="false" onAction="#limpiarFormulario"
                                styleClass="secondary-button" text="Limpiar"/>
                        <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#registrarEntrada"
                                styleClass="primary-button" text="Registrar Entrada"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- REFUERZO INMEDIATO: ÚLTIMOS INGRESOS -->
        <VBox maxWidth="960.0" spacing="8.0" styleClass="table-card" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
            </padding>
            <children>
                <Label styleClass="module-section-title" text="Últimos Ingresos Registrados"/>
                <TableView fx:id="tablaIngresos" prefHeight="220.0" maxWidth="Infinity">
                    <columns>
                        <TableColumn fx:id="colHora" prefWidth="110.0" text="Hora"/>
                        <TableColumn fx:id="colNombre" prefWidth="220.0" text="Residente"/>
                        <TableColumn fx:id="colDepto" prefWidth="150.0" text="Departamento"/>
                        <TableColumn fx:id="colMotivo" prefWidth="220.0" text="Motivo"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
