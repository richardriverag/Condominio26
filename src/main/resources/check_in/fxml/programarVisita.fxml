<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER"
      maxHeight="1.7976931348623157E308"
      maxWidth="1.7976931348623157E308"
      prefHeight="600.0"
      prefWidth="900.0"
      spacing="16.0"
      styleClass="module-content"
      stylesheets="@../css/checkInStyles.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fis.dsw.sgc.check_in.controller.ProgramarVisitaController">

    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/>
    </padding>

    <children>
        <VBox alignment="CENTER" maxWidth="960.0" spacing="4.0">
            <children>
                <Label styleClass="module-title" text="Programar Visita"/>
                <Label styleClass="module-subtitle"
                       text="Registre los datos de su visitante para agilizar su ingreso al condominio."/>
            </children>
        </VBox>

        <!-- FORMULARIO -->
        <VBox maxWidth="960.0" spacing="14.0" styleClass="module-card">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
            </padding>
            <children>
                <GridPane hgap="12.0" vgap="14.0" maxWidth="1.7976931348623157E308">
                    <columnConstraints>
                        <ColumnConstraints minWidth="150.0" prefWidth="160.0"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" prefWidth="360.0"/>
                    </columnConstraints>
                    <children>
                        <Label styleClass="form-label" text="Nombre del visitante"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtNombreVisitante" promptText="Nombre completo"
                                   maxWidth="1.7976931348623157E308"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label styleClass="form-label" text="Identificación"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtIdentificacionVisitante" promptText="Cédula / pasaporte"
                                   maxWidth="1.7976931348623157E308"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label styleClass="form-label" text="Placa de vehículo (opcional)"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtPlaca" promptText="ABC-1234"
                                   maxWidth="1.7976931348623157E308"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label styleClass="form-label" text="Unidad relacionada"
                               GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtUnidad" promptText="Ej. Depto. 302"
                                   maxWidth="1.7976931348623157E308"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label styleClass="form-label" text="Motivo de la visita"
                               GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <TextField fx:id="txtMotivo" promptText="Ej. Reunión familiar"
                                   maxWidth="1.7976931348623157E308"
                                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                        <Label styleClass="form-label" text="Fecha estimada"
                               GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <HBox spacing="12.0" GridPane.columnIndex="1" GridPane.rowIndex="5">
                            <children>
                                <DatePicker fx:id="dpFecha" promptText="Fecha" prefWidth="160.0"/>
                                <TextField fx:id="txtHora" promptText="HH:mm" prefWidth="100.0"/>
                            </children>
                        </HBox>
                    </children>
                </GridPane>

                <Label fx:id="lblMensaje" styleClass="message-label"/>

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Button fx:id="btnLimpiar" mnemonicParsing="false" onAction="#limpiarFormulario"
                                styleClass="secondary-button" text="Limpiar"/>
                        <Button fx:id="btnProgramar" mnemonicParsing="false" onAction="#programarVisita"
                                styleClass="primary-button" text="Programar Visita"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- MIS VISITAS PROGRAMADAS -->
        <VBox maxWidth="960.0" spacing="8.0" styleClass="table-card" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
            </padding>
            <children>
                <Label styleClass="module-section-title" text="Mis Visitas Programadas"/>
                <TableView fx:id="tablaVisitas" prefHeight="240.0" maxWidth="Infinity">
                    <columns>
                        <TableColumn fx:id="colVisitante" prefWidth="180.0" text="Visitante"/>
                        <TableColumn fx:id="colFecha" prefWidth="110.0" text="Fecha"/>
                        <TableColumn fx:id="colHora" prefWidth="90.0" text="Hora"/>
                        <TableColumn fx:id="colMotivo" prefWidth="180.0" text="Motivo"/>
                        <TableColumn fx:id="colEstado" prefWidth="120.0" text="Estado" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colOpciones" prefWidth="120.0" text="Opciones" style="-fx-alignment: CENTER;"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
