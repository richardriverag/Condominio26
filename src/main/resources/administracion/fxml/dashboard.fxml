<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="rootPane" prefHeight="720.0" prefWidth="1200.0"
            stylesheets="@../css/dashboardStyles.css"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fis.dsw.sgc.administracion.dashboard.mainWindowController">

   <!-- ================= SIDEBAR IZQUIERDO ================= -->
   <left>
      <VBox fx:id="sidebar" prefWidth="230.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>

            <!-- Perfil de usuario -->
            <VBox alignment="CENTER" spacing="6.0" styleClass="profile-box">
               <padding>
                  <Insets bottom="20.0" top="30.0"/>
               </padding>
               <children>
                  <StackPane styleClass="avatar-frame">
                     <children>
                        <ImageView fx:id="avatarImage" fitHeight="70.0" fitWidth="70.0"
                                   pickOnBounds="true" preserveRatio="true" styleClass="avatar-image"/>
                     </children>
                  </StackPane>
                  <Label fx:id="lblNombreUsuario" styleClass="user-name" text="Usuario"/>
                  <Label fx:id="lblRolUsuario" styleClass="user-role" text="ROL"/>
               </children>
            </VBox>

            <!-- Menú principal -->
            <VBox styleClass="menu-box">
               <children>

                  <!-- ADMINISTRACIÓN -->
                  <VBox fx:id="administracionBox">
                     <children>
                        <Button fx:id="btnAdministracion" mnemonicParsing="false"
                                onAction="#toggleAdministracion" styleClass="menu-item" text="ADMINISTRACIÓN">
                           <graphic>
                              <FontIcon iconLiteral="fa-cogs" iconSize="16"/>
                           </graphic>
                        </Button>
                        <VBox fx:id="submenuAdministracion" managed="false" styleClass="submenu" visible="false">
                           <children>
                              <Button mnemonicParsing="false" onAction="#opcionPendiente"
                                      styleClass="submenu-item" text="Opción 1"/>
                              <Button mnemonicParsing="false" onAction="#opcionPendiente"
                                      styleClass="submenu-item" text="Opción 2"/>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <!-- FINANZAS -->
                  <VBox fx:id="finanzasBox">
                     <children>
                        <Button fx:id="btnFinanzas" mnemonicParsing="false" onAction="#toggleFinanzas"
                                styleClass="menu-item" text="FINANZAS">
                           <graphic>
                              <FontIcon iconLiteral="fa-money" iconSize="16"/>
                           </graphic>
                        </Button>
                        <VBox fx:id="submenuFinanzas" managed="false" styleClass="submenu" visible="false">
                           <children>
                              <Button mnemonicParsing="false" onAction="#irARegistrarPagoExterno"
                                      styleClass="submenu-item" text="Registrar Pago Externo"/>
                              <Button mnemonicParsing="false" onAction="#irAGenerarRendicionCuentas"
                                      styleClass="submenu-item" text="Generar Rendición Cuentas"/>
                              <Button mnemonicParsing="false" onAction="#irAValidarPago"
                                      styleClass="submenu-item" text="Validar Pago"/>
                              <Button mnemonicParsing="false" onAction="#irAConsultarDeudas"
                                      styleClass="submenu-item" text="Consultar Deudas"/>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <!-- INMUEBLES -->
                  <VBox fx:id="inmueblesBox">
                     <children>
                        <Button fx:id="btnInmuebles" mnemonicParsing="false" onAction="#toggleInmuebles"
                                styleClass="menu-item" text="INMUEBLES">
                           <graphic>
                              <FontIcon iconLiteral="fa-building" iconSize="16"/>
                           </graphic>
                        </Button>
                        <VBox fx:id="submenuInmuebles" managed="false" styleClass="submenu" visible="false">
                           <children>
                              <Button mnemonicParsing="false" onAction="#opcionPendiente"
                                      styleClass="submenu-item" text="Opción 1"/>
                              <Button mnemonicParsing="false" onAction="#opcionPendiente"
                                      styleClass="submenu-item" text="Opción 2"/>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <!-- RESERVAS -->
                  <VBox fx:id="reservasBox">
                     <children>
                        <Button fx:id="btnReservas" mnemonicParsing="false" onAction="#toggleReservas"
                                styleClass="menu-item" text="RESERVAS">
                           <graphic>
                              <FontIcon iconLiteral="fa-calendar" iconSize="16"/>
                           </graphic>
                        </Button>
                        <VBox fx:id="submenuReservas" managed="false" styleClass="submenu" visible="false">
                           <children>
                              <Button mnemonicParsing="false" onAction="#irAAnadirReserva"
                                      styleClass="submenu-item" text="Añadir Reserva"/>
                              <Button mnemonicParsing="false" onAction="#irAVerReserva"
                                      styleClass="submenu-item" text="Ver Reserva"/>
                              <Button mnemonicParsing="false" onAction="#irAAgregarObservacion"
                                      styleClass="submenu-item" text="Agregar Observación"/>
                              <Button mnemonicParsing="false" onAction="#irACancelarObservacion"
                                      styleClass="submenu-item" text="Cancelar Observación"/>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <!-- CHECK-IN -->
                  <VBox fx:id="checkInBox">
                     <children>
                        <Button fx:id="btnCheckIn" mnemonicParsing="false" onAction="#toggleCheckIn"
                                styleClass="menu-item" text="CHECK-IN">
                           <graphic>
                              <FontIcon iconLiteral="fa-sign-in" iconSize="16"/>
                           </graphic>
                        </Button>
                        <VBox fx:id="submenuCheckIn" managed="false" styleClass="submenu" visible="false">
                           <children>
                              <Button mnemonicParsing="false" onAction="#irARegistrarEntradaResidente"
                                      styleClass="submenu-item" text="Registrar entrada de residente"/>
                              <Button mnemonicParsing="false" onAction="#irARegistrarEntradaExterna"
                                      styleClass="submenu-item" text="Registrar entrada externa"/>
                              <Button mnemonicParsing="false" onAction="#irAProgramarVisita"
                                      styleClass="submenu-item" text="Programar visita"/>
                              <Button mnemonicParsing="false" onAction="#irAGestionarHistorialIngresos"
                                      styleClass="submenu-item" text="Gestionar historial de ingresos"/>
                              <Button mnemonicParsing="false" onAction="#irAEnviarAlerta"
                                      styleClass="submenu-item" text="Enviar alerta"/>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <!-- COMUNICACIÓN -->
                  <VBox fx:id="comunicacionBox">
                     <children>
                        <Button fx:id="btnComunicacion" mnemonicParsing="false" onAction="#toggleComunicacion"
                                styleClass="menu-item" text="COMUNICACIÓN">
                           <graphic>
                              <FontIcon iconLiteral="fa-comments" iconSize="16"/>
                           </graphic>
                        </Button>
                        <VBox fx:id="submenuComunicacion" managed="false" styleClass="submenu" visible="false">
                           <children>
                              <Button mnemonicParsing="false" onAction="#opcionPendiente"
                                      styleClass="submenu-item" text="Opción 1"/>
                              <Button mnemonicParsing="false" onAction="#opcionPendiente"
                                      styleClass="submenu-item" text="Opción 2"/>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

               </children>
            </VBox>

            <!-- Espaciador: empuja el footer hacia abajo -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Footer: inicio / cerrar sesión -->
            <HBox alignment="CENTER" spacing="40.0" styleClass="footer-box">
               <padding>
                  <Insets bottom="20.0" top="20.0"/>
               </padding>
               <children>
                  <Button fx:id="btnInicio" mnemonicParsing="false" onAction="#irAInicio"
                          styleClass="footer-icon-btn">
                     <graphic>
                        <FontIcon iconLiteral="fa-home" iconSize="20"/>
                     </graphic>
                  </Button>
                  <Button fx:id="btnCerrarSesion" mnemonicParsing="false" onAction="#logOut"
                          styleClass="footer-icon-btn">
                     <graphic>
                        <FontIcon iconLiteral="fa-sign-out" iconSize="20"/>
                     </graphic>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </left>

   <!-- ================= ÁREA DE CONTENIDO ================= -->
   <center>
      <BorderPane BorderPane.alignment="CENTER">
         <top>
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="10.0" styleClass="top-bar"
                  BorderPane.alignment="CENTER">
               <padding>
                  <Insets left="25.0" right="25.0"/>
               </padding>
               <children>
                  <Label styleClass="top-bar-title" text="SISTEMA DE GESTIÓN PARA CONDOMINIOS"/>
                  <Region HBox.hgrow="ALWAYS"/>
                  <Button fx:id="btnNotificaciones" mnemonicParsing="false" onAction="#irANotificaciones"
                          styleClass="bell-btn">
                     <graphic>
                        <FontIcon iconLiteral="fa-bell" iconSize="20" styleClass="bell-icon"/>
                     </graphic>
                  </Button>
               </children>
            </HBox>
         </top>
         <center>
            <StackPane fx:id="contentPane" styleClass="content-pane" BorderPane.alignment="CENTER"/>
         </center>
      </BorderPane>
   </center>

</BorderPane>
