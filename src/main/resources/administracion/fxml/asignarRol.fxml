<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="900.0" spacing="16.0"
      styleClass="module-content" stylesheets="@../css/administracionStyles.css"
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">

    <padding><Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/></padding>

    <Label styleClass="module-title" text="Asignar Rol a Usuario"/>
    <Label styleClass="module-subtitle" text="Busque un usuario para modificar sus niveles de acceso."/>

    <VBox maxWidth="640.0" spacing="14.0" styleClass="module-card">
        <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0"/></padding>
        <Label styleClass="form-label" text="Correo del Usuario"/>
        <HBox spacing="10.0">
            <TextField fx:id="txtBuscarCorreo" promptText="correo@ejemplo.com" HBox.hgrow="ALWAYS"/>
            <Button mnemonicParsing="false" onAction="#buscarUsuario" styleClass="secondary-button" text="Buscar"/>
        </HBox>
        <Label fx:id="lblMensajeBusqueda" styleClass="message-label"/>
    </VBox>

    <VBox fx:id="panelAsignacion" maxWidth="640.0" spacing="16.0" styleClass="module-card" visible="false" managed="false">
        <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/></padding>

        <Label styleClass="module-section-title" text="Información del Usuario"/>
        <HBox spacing="10.0">
            <Label text="Nombre: " styleClass="form-label"/>
            <Label fx:id="lblUsuarioEncontrado"/>
        </HBox>
        <HBox spacing="10.0">
            <Label text="Roles Actuales: " styleClass="form-label"/>
            <Label fx:id="lblRolesActuales" styleClass="message-info"/>
        </HBox>

        <Label styleClass="form-label" text="Seleccione el nuevo rol a asignar"/>
        <ComboBox fx:id="cmbNuevosRoles" prefWidth="300.0"/>

        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <Region HBox.hgrow="ALWAYS"/>
            <Button mnemonicParsing="false" onAction="#asignarRol" styleClass="primary-button" text="Guardar Cambios"/>
        </HBox>
        <Label fx:id="lblMensajeAsignacion" styleClass="message-label"/>
    </VBox>
</VBox>