<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="fis.dsw.sgc.administracion.controller.ActualizarInformacionDeCuentaController"
      alignment="TOP_CENTER"
      maxHeight="1.7976931348623157E308"
      maxWidth="1.7976931348623157E308"
      prefHeight="600.0"
      prefWidth="900.0"
      spacing="16.0"
      styleClass="module-content"
      stylesheets="@../css/administracionStyles.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/>
    </padding>

    <children>
        <Label styleClass="module-title" text="Actualizar información de cuenta"/>
        <Label styleClass="module-subtitle"
               text="Busque una cuenta por correo electrónico para editar sus datos."/>

        <!-- Panel de búsqueda -->
        <VBox maxWidth="640.0" spacing="14.0" styleClass="module-card">
            <padding>
                <Insets bottom="20.0" left="24.0" right="24.0" top="20.0"/>
            </padding>
            <children>
                <Label styleClass="form-label" text="Correo de la cuenta a buscar"/>
                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="txtBuscarCorreo" promptText="correo@condominio.local"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnBuscar" mnemonicParsing="false" onAction="#buscarCuenta"
                                styleClass="secondary-button" text="Buscar"/>
                    </children>
                </HBox>
                <Label fx:id="lblMensajeBusqueda" styleClass="message-label" text="" wrapText="true"/>
            </children>
        </VBox>

        <!-- Panel de edición (solo visible tras encontrar la cuenta) -->
        <VBox fx:id="panelEdicion" maxWidth="640.0" spacing="16.0" styleClass="module-card"
              visible="false" managed="false">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label styleClass="module-section-title" text="Datos de la cuenta"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblEstadoCuenta" styleClass="badge-estado" text="ACTIVA"/>
                    </children>
                </HBox>

                <HBox spacing="16.0">
                    <children>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="form-label" text="Nombre"/>
                                <TextField fx:id="txtNombre"/>
                            </children>
                        </VBox>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="form-label" text="Apellido"/>
                                <TextField fx:id="txtApellido"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="6.0">
                    <children>
                        <Label styleClass="form-label" text="Correo"/>
                        <TextField fx:id="txtCorreo"/>
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#cancelar"
                                styleClass="secondary-button" text="Cancelar"/>
                        <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#guardar"
                                styleClass="primary-button" text="Guardar cambios"/>
                    </children>
                </HBox>

                <Label fx:id="lblMensajeEdicion" styleClass="message-label" text="" wrapText="true"/>
            </children>
        </VBox>
    </children>
</VBox>