<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="fis.dsw.sgc.administracion.controller.DefinirPermisosController"
      alignment="TOP_CENTER" prefHeight="600.0" prefWidth="900.0" spacing="16.0"
      styleClass="module-content" stylesheets="@../css/administracionStyles.css"
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">

    <padding><Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/></padding>

    <Label styleClass="module-title" text="Definir Permisos de Rol"/>
    <Label styleClass="module-subtitle" text="Configure los recursos y accesos para cada rol del sistema."/>

    <VBox maxWidth="640.0" spacing="16.0" styleClass="module-card">
        <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/></padding>

        <VBox spacing="6.0">
            <Label styleClass="form-label" text="Seleccione el Rol"/>
            <ComboBox fx:id="cmbRoles" prefWidth="300.0"/>
        </VBox>

        <VBox spacing="6.0">
            <Label styleClass="form-label" text="Nombre del Permiso (Ej. LECTURA_REPORTES)"/>
            <TextField fx:id="txtNombrePermiso"/>
        </VBox>

        <VBox spacing="6.0">
            <Label styleClass="form-label" text="Recurso Asociado (Ej. /finanzas/reportes)"/>
            <TextField fx:id="txtRecurso"/>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <Region HBox.hgrow="ALWAYS"/>
            <Button mnemonicParsing="false" onAction="#guardarPermiso" styleClass="primary-button" text="Guardar Permisos"/>
        </HBox>
        <Label fx:id="lblMensaje" styleClass="message-label"/>
    </VBox>
</VBox>