<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0" prefWidth="900.0" spacing="20.0" styleClass="module-content" stylesheets="@../css/inmueblesStyles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
   <children>

      <Label styleClass="module-title" text="Registrar Caso Fortuito" />
      <Label styleClass="module-subtitle" text="Reporte incidentes o eventos imprevistos ocurridos en un inmueble (daños, fugas, incendios, etc.)." />

      <VBox maxWidth="620.0" spacing="12.0" styleClass="module-card">
         <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
         </padding>
         <children>
            <Label styleClass="field-label" text="BUSCAR INMUEBLE POR CÓDIGO" />
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <TextField fx:id="txtBuscarCodigo" maxWidth="1.7976931348623157E308" promptText="Ej. A-101" HBox.hgrow="ALWAYS" onAction="#buscar" />
                  <Button mnemonicParsing="false" onAction="#buscar" styleClass="primary-button" text="Buscar" />
               </children>
            </HBox>
            <Label fx:id="lblInmuebleInfo" styleClass="module-subtitle" text=" " wrapText="true" />
         </children>
      </VBox>

      <VBox maxWidth="680.0" spacing="14.0" styleClass="module-card">
         <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
         </padding>
         <children>
            <Label styleClass="section-title" text="DESCRIPCIÓN DEL INCIDENTE" />
            <TextArea fx:id="txtDescripcion" disable="true" prefRowCount="4" promptText="Describa qué ocurrió, cuándo y el alcance del daño (opcional agregar ubicación exacta)." wrapText="true" />

            <Label fx:id="lblMensaje" styleClass="message-label" text=" " wrapText="true" />

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#registrar" styleClass="primary-button" text="Registrar caso" />
         </children>
      </VBox>

      <VBox maxWidth="680.0" spacing="10.0" styleClass="module-card" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
         </padding>
         <children>
            <Label styleClass="section-title" text="HISTORIAL DE CASOS DEL INMUEBLE" />
            <TableView fx:id="tablaCasos" maxWidth="1.7976931348623157E308" prefHeight="220.0" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colFecha" prefWidth="150.0" text="Fecha" />
                  <TableColumn fx:id="colDescripcion" prefWidth="330.0" text="Descripción" />
                  <TableColumn fx:id="colEstado" prefWidth="140.0" text="Estado" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>

      <Region VBox.vgrow="NEVER" />

   </children>
</VBox>