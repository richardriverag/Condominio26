<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" spacing="20.0" styleClass="module-content" stylesheets="@../css/inmueblesStyles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
   <children>

      <!-- Título -->
      <Label styleClass="module-title" text="Gestión de Inmuebles" />

      <!-- Tarjeta de búsqueda: AHORA sí tiene contenido adentro, y por
           eso ya no reserva un hueco vacío de 200px como antes.
           El HBox de búsqueda va DENTRO de la tarjeta, no suelto. -->
      <VBox maxWidth="520.0" spacing="12.0" styleClass="module-card">
         <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <TextField maxWidth="1.7976931348623157E308" promptText="Buscar por código o dirección" HBox.hgrow="ALWAYS" />
                  <Button maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="primary-button" text="Buscar" />
               </children>
            </HBox>
         </children>
      </VBox>

      <!-- Este Region es el único que SÍ debe crecer: absorbe todo el
           espacio sobrante para que no quede como hueco flotante al
           final de la pantalla. Reemplaza tu VBox de "hola / Label"
           que era una prueba y ya no la necesitas. -->
      <Region VBox.vgrow="ALWAYS" />
      <HBox prefHeight="29.0" prefWidth="820.0" spacing="230.0" VBox.vgrow="ALWAYS">
         <children>
            <Button mnemonicParsing="false" text="Button" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" text="Button" HBox.hgrow="ALWAYS" />
            <TextField HBox.hgrow="ALWAYS" />
         </children>
         <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="10.0" />
         </padding>
      </HBox>

   </children>
</VBox>
