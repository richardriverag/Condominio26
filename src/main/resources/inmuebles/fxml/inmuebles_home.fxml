<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" spacing="20.0" styleClass="module-content" stylesheets="@../css/inmueblesStyles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
   <children>

      <!-- Título -->
      <Label styleClass="module-title" text="Gestión de Inmuebles" />

      <!-- Tarjeta de búsqueda -->
      <VBox maxWidth="520.0" spacing="12.0" styleClass="module-card">
         <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <TextField fx:id="txtBuscar" maxWidth="1.7976931348623157E308" promptText="Buscar por código, edificio o propietario" HBox.hgrow="ALWAYS" onAction="#buscar" />
                  <Button fx:id="btnBuscar" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="primary-button" text="Buscar" onAction="#buscar" />
               </children>
            </HBox>
         </children>
      </VBox>

      <!-- Tarjeta de la tabla de inmuebles -->
      <VBox spacing="10.0" styleClass="module-card" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
         </padding>
         <children>
            <Label fx:id="lblMensaje" styleClass="module-subtitle" text=" " />
            <TableView fx:id="tablaInmuebles" maxWidth="1.7976931348623157E308" prefHeight="360.0" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colCodigo" prefWidth="110.0" text="Código" />
                  <TableColumn fx:id="colDireccion" prefWidth="220.0" text="Ubicación" />
                  <TableColumn fx:id="colTipo" prefWidth="150.0" text="Tipo" />
                  <TableColumn fx:id="colPropietario" prefWidth="200.0" text="Propietario" />
                  <TableColumn fx:id="colEstado" prefWidth="130.0" text="Estado" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>

      <Region VBox.vgrow="NEVER" />

   </children>
</VBox>