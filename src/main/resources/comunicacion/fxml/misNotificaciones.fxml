<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.FlowPane?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fis.dsw.sgc.comunicacion.controller.MisNotificacionesController"
            prefWidth="950.0"
            prefHeight="650.0"
            style="-fx-background-color: #f5f7fb;">

    <top>
        <VBox spacing="12.0">
            <padding>
                <Insets top="20.0"
                        right="20.0"
                        bottom="15.0"
                        left="20.0"/>
            </padding>

            <Label text="Mis notificaciones"
                   style="-fx-font-size: 24px;
              -fx-font-weight: bold;
              -fx-text-fill: #1f2937;"/>

            <Label fx:id="lblUsuario"
                   text="Usuario"
                   style="-fx-font-size: 14px;
              -fx-text-fill: #475569;"/>

            <FlowPane hgap="10.0"
                      vgap="10.0"
                      prefWrapLength="850.0">

                <ComboBox fx:id="cmbTipo"
                          prefWidth="150.0"
                          promptText="Tipo"/>

                <ComboBox fx:id="cmbEstado"
                          prefWidth="150.0"
                          promptText="Estado"/>

                <TextField fx:id="txtBusqueda"
                           prefWidth="220.0"
                           promptText="Buscar por asunto..."/>

                <Button text="Buscar"
                        minWidth="75.0"
                        onAction="#aplicarFiltros"/>

                <Button text="Limpiar"
                        minWidth="75.0"
                        onAction="#limpiarFiltros"/>

                <Button text="Actualizar"
                        minWidth="90.0"
                        onAction="#actualizarNotificaciones"/>

            </FlowPane>
        </VBox>
    </top>

    <center>
        <VBox spacing="10.0">
            <padding>
                <Insets top="5.0"
                        right="20.0"
                        bottom="10.0"
                        left="20.0"/>
            </padding>

            <TableView fx:id="tblNotificaciones"
                       VBox.vgrow="ALWAYS"
                       onMouseClicked="#seleccionarNotificacion">

                <columns>
                    <TableColumn fx:id="colFecha"
                                 text="Fecha"
                                 prefWidth="170.0"/>

                    <TableColumn fx:id="colTipo"
                                 text="Tipo"
                                 prefWidth="150.0"/>

                    <TableColumn fx:id="colAsunto"
                                 text="Asunto"
                                 prefWidth="390.0"/>

                    <TableColumn fx:id="colEstado"
                                 text="Estado"
                                 prefWidth="140.0"/>
                </columns>
            </TableView>

            <Label fx:id="lblResumen"
                   text="0 notificaciones"
                   style="-fx-text-fill: #334155;
              -fx-font-size: 13px;"/>

            <Label fx:id="lblMensaje"
                   text=""
                   wrapText="true"
                   style="-fx-text-fill: #334155;"/>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="12.0"
              alignment="CENTER_RIGHT">
            <padding>
                <Insets top="10.0"
                        right="20.0"
                        bottom="20.0"
                        left="20.0"/>
            </padding>

            <Button fx:id="btnMarcarLeida"
                    text="Marcar como leída"
                    onAction="#marcarLeida"/>

            <Button fx:id="btnEliminar"
                    text="Eliminar"
                    onAction="#eliminar"/>
        </HBox>
    </bottom>

</BorderPane>