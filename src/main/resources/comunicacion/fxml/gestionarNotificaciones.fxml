<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fis.dsw.sgc.comunicacion.controller.GestionarNotificacionesController"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            pannable="true" styleClass="module-scroll-pane"
            stylesheets="@../css/comunicacionStyles.css">
    <content>
        <VBox alignment="TOP_CENTER" fillWidth="true" spacing="18" styleClass="module-content">
            <padding><Insets top="32" right="32" bottom="42" left="32"/></padding>

            <VBox alignment="CENTER" maxWidth="980" spacing="5">
                <Label styleClass="module-eyebrow" text="CENTRO DE NOTIFICACIONES"/>
                <Label styleClass="module-title" text="Gestionar notificaciones"/>
                <Label maxWidth="760" styleClass="module-subtitle"
                       text="Consulte, filtre y administre las notificaciones generadas por Comunicación."
                       textAlignment="CENTER" wrapText="true"/>
            </VBox>

            <VBox maxWidth="980" spacing="16" styleClass="module-card">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <HBox styleClass="section-header">
                        <Label styleClass="section-badge" text="1"/>
                        <VBox spacing="2">
                            <Label styleClass="module-section-title" text="Filtros de consulta"/>
                            <Label styleClass="table-subtitle"
                                   text="Localice notificaciones por tipo, estado o contenido."/>
                        </VBox>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblResumen" styleClass="summary-label" text="0 notificación(es)"/>
                </HBox>

                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="28"/>
                        <ColumnConstraints percentWidth="28"/>
                        <ColumnConstraints percentWidth="44"/>
                    </columnConstraints>
                    <VBox spacing="6" GridPane.columnIndex="0">
                        <Label styleClass="form-label" text="Tipo"/>
                        <ComboBox fx:id="cmbTipo" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="1">
                        <Label styleClass="form-label" text="Estado"/>
                        <ComboBox fx:id="cmbEstado" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="2">
                        <Label styleClass="form-label" text="Destinatario, asunto o contenido"/>
                        <TextField fx:id="txtBusqueda" maxWidth="Infinity"
                                   promptText="Escriba un criterio de búsqueda"/>
                    </VBox>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button onAction="#limpiarFiltros" styleClass="secondary-button" text="Limpiar filtros"/>
                    <Button onAction="#aplicarFiltros" styleClass="primary-button"
                            text="Aplicar filtros" defaultButton="true"/>
                </HBox>
            </VBox>

            <VBox maxWidth="980" minHeight="500" spacing="12" styleClass="table-card">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <VBox spacing="3">
                    <Label styleClass="module-section-title" text="Listado de notificaciones"/>
                    <Label styleClass="table-subtitle"
                           text="Seleccione una fila para marcarla como leída o eliminarla."/>
                </VBox>
                <TableView fx:id="tblNotificaciones" minHeight="360" prefHeight="360"
                           maxWidth="Infinity" onMouseClicked="#seleccionarNotificacion" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFecha" text="Fecha" prefWidth="145"/>
                        <TableColumn fx:id="colTipo" text="Tipo" prefWidth="135"/>
                        <TableColumn fx:id="colDestinatario" text="Destinatario" prefWidth="190"/>
                        <TableColumn fx:id="colAsunto" text="Asunto" prefWidth="280"/>
                        <TableColumn fx:id="colEstado" text="Estado" prefWidth="115"/>
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/></columnResizePolicy>
                </TableView>
                <Label fx:id="lblMensaje" minHeight="18" maxWidth="Infinity"
                       styleClass="message-label" wrapText="true"/>
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button onAction="#actualizarNotificaciones" styleClass="secondary-button" text="Actualizar"/>
                    <Button fx:id="btnEliminar" onAction="#eliminar" styleClass="danger-button" text="Eliminar"/>
                    <Button fx:id="btnMarcarLeida" onAction="#marcarLeida"
                            styleClass="primary-button" text="Marcar como leída"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
