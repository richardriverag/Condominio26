<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fis.dsw.sgc.comunicacion.controller.ConsultarHistorialController"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            pannable="true" styleClass="module-scroll-pane"
            stylesheets="@../css/comunicacionStyles.css">
    <content>
        <VBox alignment="TOP_CENTER" fillWidth="true" spacing="18" styleClass="module-content">
            <padding><Insets top="32" right="32" bottom="42" left="32"/></padding>

            <VBox alignment="CENTER" maxWidth="980" spacing="5">
                <Label styleClass="module-eyebrow" text="TRAZABILIDAD"/>
                <Label styleClass="module-title" text="Consultar historial"/>
                <Label maxWidth="760" styleClass="module-subtitle"
                       text="Revise las acciones registradas para mensajes, anuncios y notificaciones."
                       textAlignment="CENTER" wrapText="true"/>
            </VBox>

            <VBox maxWidth="980" spacing="16" styleClass="module-card">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <HBox styleClass="section-header">
                    <Label styleClass="section-badge" text="1"/>
                    <VBox spacing="2">
                        <Label styleClass="module-section-title" text="Filtros de búsqueda"/>
                        <Label styleClass="table-subtitle"
                               text="Seleccione un rango y refine la consulta."/>
                    </VBox>
                </HBox>

                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25" hgrow="SOMETIMES"/>
                        <ColumnConstraints percentWidth="25" hgrow="SOMETIMES"/>
                        <ColumnConstraints percentWidth="25" hgrow="SOMETIMES"/>
                        <ColumnConstraints percentWidth="25" hgrow="SOMETIMES"/>
                    </columnConstraints>
                    <VBox spacing="6" GridPane.columnIndex="0">
                        <Label styleClass="form-label" text="Fecha desde"/>
                        <DatePicker fx:id="dpFechaDesde" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="1">
                        <Label styleClass="form-label" text="Fecha hasta"/>
                        <DatePicker fx:id="dpFechaHasta" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="2">
                        <Label styleClass="form-label" text="Tipo"/>
                        <ComboBox fx:id="cmbTipo" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="3">
                        <Label styleClass="form-label" text="Estado"/>
                        <ComboBox fx:id="cmbEstado" maxWidth="Infinity"/>
                    </VBox>
                </GridPane>

                <VBox spacing="6">
                    <Label styleClass="form-label" text="Asunto, emisor o palabra clave"/>
                    <TextField fx:id="txtBusqueda" maxWidth="Infinity"
                               promptText="Escriba un criterio de búsqueda"/>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button onAction="#limpiarFiltros" styleClass="secondary-button" text="Limpiar filtros"/>
                    <Button onAction="#buscar" styleClass="primary-button" text="Buscar" defaultButton="true"/>
                </HBox>
            </VBox>

            <VBox maxWidth="980" minHeight="520" spacing="12" styleClass="table-card">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="3">
                        <Label styleClass="module-section-title" text="Historial de comunicaciones"/>
                        <Label styleClass="table-subtitle"
                               text="Resultados almacenados en historial_comunicacion."/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblTotalResultados" styleClass="summary-label" text="0 resultado(s)"/>
                </HBox>

                <TableView fx:id="tblHistorial" minHeight="330" prefHeight="330"
                           maxWidth="Infinity" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFecha" text="Fecha" prefWidth="140"/>
                        <TableColumn fx:id="colTipo" text="Tipo" prefWidth="155"/>
                        <TableColumn fx:id="colPrioridad" text="Prioridad" prefWidth="95"/>
                        <TableColumn fx:id="colAsunto" text="Asunto" prefWidth="260"/>
                        <TableColumn fx:id="colEstado" text="Estado" prefWidth="110"/>
                        <TableColumn fx:id="colEmisor" text="Emisor" prefWidth="160"/>
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/></columnResizePolicy>
                </TableView>

                <VBox spacing="6" styleClass="detail-card">
                    <Label styleClass="form-label" text="Detalle del registro"/>
                    <Label fx:id="lblDetalleSeleccionado" maxWidth="Infinity"
                           styleClass="detail-text"
                           text="Seleccione un registro para consultar su detalle." wrapText="true"/>
                </VBox>

                <Label fx:id="lblMensaje" minHeight="18" maxWidth="Infinity"
                       styleClass="message-label" wrapText="true"/>
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button onAction="#actualizarHistorial" styleClass="secondary-button" text="Actualizar"/>
                    <Button onAction="#verDetalle" styleClass="primary-button" text="Ver detalle"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
