<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fis.dsw.sgc.comunicacion.controller.PublicarAnuncioController"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            pannable="true" styleClass="module-scroll-pane"
            stylesheets="@../css/comunicacionStyles.css">
    <content>
        <VBox alignment="TOP_CENTER" fillWidth="true" spacing="18" styleClass="module-content">
            <padding><Insets top="32" right="32" bottom="42" left="32"/></padding>

            <VBox alignment="CENTER" maxWidth="980" spacing="5">
                <Label styleClass="module-eyebrow" text="TABLÓN INSTITUCIONAL"/>
                <Label styleClass="module-title" text="Publicar anuncio"/>
                <Label maxWidth="760" styleClass="module-subtitle"
                       text="Cree anuncios visibles para la comunidad y controle su periodo de vigencia."
                       textAlignment="CENTER" wrapText="true"/>
            </VBox>

            <VBox maxWidth="980" spacing="16" styleClass="module-card">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <HBox styleClass="section-header">
                    <Label styleClass="section-badge" text="1"/>
                    <VBox spacing="2">
                        <Label styleClass="module-section-title" text="Clasificación y vigencia"/>
                        <Label styleClass="table-subtitle"
                               text="Defina el propósito, prioridad y duración del anuncio."/>
                    </VBox>
                </HBox>

                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" hgrow="SOMETIMES" minWidth="220"/>
                        <ColumnConstraints percentWidth="50" hgrow="SOMETIMES" minWidth="220"/>
                    </columnConstraints>
                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label styleClass="form-label" text="Tipo de anuncio"/>
                        <ComboBox fx:id="cmbTipoAnuncio" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label styleClass="form-label" text="Prioridad"/>
                        <ComboBox fx:id="cmbPrioridad" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label styleClass="form-label" text="Fecha de publicación"/>
                        <DatePicker fx:id="dpFechaPublicacion" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label styleClass="form-label" text="Fecha de expiración"/>
                        <DatePicker fx:id="dpFechaExpiracion" maxWidth="Infinity"/>
                    </VBox>
                </GridPane>

                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="form-label" text="Título"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblContadorTitulo" styleClass="character-counter" text="0 / 120"/>
                    </HBox>
                    <TextField fx:id="txtTitulo" maxWidth="Infinity"
                               promptText="Escriba un título breve y descriptivo"/>
                </VBox>
            </VBox>

            <VBox maxWidth="980" spacing="12" styleClass="module-card">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <HBox styleClass="section-header">
                    <Label styleClass="section-badge" text="2"/>
                    <VBox spacing="2">
                        <Label styleClass="module-section-title" text="Contenido del anuncio"/>
                        <Label styleClass="table-subtitle"
                               text="Redacte la información que aparecerá en el tablón institucional."/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblContadorContenido" styleClass="character-counter" text="0 / 2000"/>
                </HBox>
                <TextArea fx:id="txtContenido" minHeight="190" prefHeight="190"
                          maxWidth="Infinity" wrapText="true"
                          promptText="Redacte el contenido del anuncio..."/>
                <Label styleClass="form-hint"
                       text="El anuncio generará notificaciones para los usuarios activos." wrapText="true"/>
            </VBox>

            <VBox maxWidth="980" spacing="12" styleClass="module-card action-card">
                <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>
                <Label fx:id="lblMensaje" minHeight="18" maxWidth="Infinity"
                       styleClass="message-label" wrapText="true"/>
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button onAction="#cancelar" styleClass="secondary-button" text="Cancelar"/>
                    <Button onAction="#limpiarFormulario" styleClass="secondary-button" text="Limpiar"/>
                    <Button fx:id="btnPublicar" onAction="#publicarAnuncio"
                            styleClass="primary-button" text="Publicar anuncio" defaultButton="true"/>
                </HBox>
            </VBox>

            <VBox maxWidth="980" minHeight="390" spacing="12" styleClass="table-card">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <VBox spacing="3">
                    <Label styleClass="module-section-title" text="Anuncios recientes"/>
                    <Label styleClass="table-subtitle" text="Últimos anuncios almacenados en SQLite."/>
                </VBox>
                <TableView fx:id="tblAnunciosRecientes" minHeight="300" prefHeight="300"
                           maxWidth="Infinity" onMouseClicked="#seleccionarAnuncio" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFecha" text="Fecha" prefWidth="120"/>
                        <TableColumn fx:id="colTipo" text="Tipo" prefWidth="170"/>
                        <TableColumn fx:id="colPrioridad" text="Prioridad" prefWidth="100"/>
                        <TableColumn fx:id="colTitulo" text="Título" prefWidth="250"/>
                        <TableColumn fx:id="colVigencia" text="Vigencia" prefWidth="185"/>
                        <TableColumn fx:id="colEstado" text="Estado" prefWidth="110"/>
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/></columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
