<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fis.dsw.sgc.comunicacion.controller.EnviarMensajeController"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            pannable="true" prefHeight="700" prefWidth="1050"
            styleClass="module-scroll-pane" stylesheets="@../css/comunicacionStyles.css">
    <content>
        <VBox alignment="TOP_CENTER" fillWidth="true" spacing="18" styleClass="module-content">
            <padding><Insets top="32" right="32" bottom="42" left="32"/></padding>

            <VBox alignment="CENTER" maxWidth="980" spacing="5">
                <Label styleClass="module-eyebrow" text="COMUNICACIÓN INSTITUCIONAL"/>
                <Label styleClass="module-title" text="Enviar mensaje"/>
                <Label maxWidth="760" styleClass="module-subtitle"
                       text="Redacte, valide y distribuya mensajes a los diferentes grupos del condominio."
                       textAlignment="CENTER" wrapText="true"/>
            </VBox>

            <VBox maxWidth="980" spacing="16" styleClass="module-card">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <HBox styleClass="section-header">
                    <Label styleClass="section-badge" text="1"/>
                    <VBox spacing="2">
                        <Label styleClass="module-section-title" text="Destinatarios y clasificación"/>
                        <Label styleClass="table-subtitle"
                               text="Defina el alcance y la prioridad de la comunicación."/>
                    </VBox>
                </HBox>

                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" hgrow="SOMETIMES" minWidth="220"/>
                        <ColumnConstraints percentWidth="50" hgrow="SOMETIMES" minWidth="220"/>
                    </columnConstraints>
                    <VBox spacing="6" GridPane.columnIndex="0">
                        <Label styleClass="form-label" text="Tipo de mensaje"/>
                        <ComboBox fx:id="cmbTipoMensaje" maxWidth="Infinity"
                                  promptText="Seleccione el tipo de comunicación"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="1">
                        <Label styleClass="form-label" text="Prioridad"/>
                        <ComboBox fx:id="cmbPrioridad" maxWidth="Infinity"
                                  promptText="Seleccione la prioridad"/>
                    </VBox>
                </GridPane>

                <HBox alignment="CENTER_LEFT" spacing="9" styleClass="recipient-info">
                    <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                    <Label styleClass="recipient-info-icon" text="i"/>
                    <Label fx:id="lblDestinatarios" maxWidth="Infinity"
                           styleClass="recipient-info-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                </HBox>

                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="form-label" text="Asunto"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblContadorAsunto" styleClass="character-counter" text="0 / 120"/>
                    </HBox>
                    <TextField fx:id="txtAsunto" maxWidth="Infinity"
                               promptText="Escriba un asunto claro y descriptivo"/>
                </VBox>
            </VBox>

            <VBox maxWidth="980" spacing="12" styleClass="module-card">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <HBox styleClass="section-header">
                    <Label styleClass="section-badge" text="2"/>
                    <VBox spacing="2">
                        <Label styleClass="module-section-title" text="Contenido del mensaje"/>
                        <Label styleClass="table-subtitle"
                               text="Escriba la información completa que recibirán los destinatarios."/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblContadorCaracteres" styleClass="character-counter" text="0 / 2000"/>
                </HBox>
                <TextArea fx:id="txtContenido" minHeight="190" prefHeight="190"
                          maxWidth="Infinity" wrapText="true"
                          promptText="Redacte aquí el contenido completo..."/>
                <Label styleClass="form-hint"
                       text="Utilice un lenguaje claro, respetuoso y apropiado para el grupo seleccionado."
                       wrapText="true"/>
            </VBox>

            <VBox maxWidth="980" spacing="12" styleClass="module-card action-card">
                <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>
                <Label fx:id="lblMensaje" minHeight="18" maxWidth="Infinity"
                       styleClass="message-label" wrapText="true"/>
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button onAction="#cancelar" styleClass="secondary-button" text="Cancelar"/>
                    <Button onAction="#limpiarFormulario" styleClass="secondary-button" text="Limpiar"/>
                    <Button fx:id="btnEnviar" onAction="#enviarMensaje"
                            styleClass="primary-button" text="Enviar mensaje" defaultButton="true"/>
                </HBox>
            </VBox>

            <VBox maxWidth="980" minHeight="390" spacing="12" styleClass="table-card">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <VBox spacing="3">
                    <Label styleClass="module-section-title" text="Historial reciente"/>
                    <Label styleClass="table-subtitle"
                           text="Últimas comunicaciones almacenadas en SQLite."/>
                </VBox>
                <TableView fx:id="tblMensajesRecientes" minHeight="300" prefHeight="300"
                           maxWidth="Infinity" onMouseClicked="#seleccionarMensaje" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFecha" text="Fecha" prefWidth="145"/>
                        <TableColumn fx:id="colTipo" text="Tipo" prefWidth="190"/>
                        <TableColumn fx:id="colPrioridad" text="Prioridad" prefWidth="105"/>
                        <TableColumn fx:id="colAsunto" text="Asunto" prefWidth="320"/>
                        <TableColumn fx:id="colEstado" text="Estado" prefWidth="115"/>
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/></columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
