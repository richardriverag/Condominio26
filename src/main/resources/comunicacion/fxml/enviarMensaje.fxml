<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fis.dsw.sgc.comunicacion.controller.EnviarMensajeController"
            fitToWidth="true"
            fitToHeight="false"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            pannable="true"
            prefHeight="600.0"
            prefWidth="900.0"
            styleClass="module-scroll-pane"
            stylesheets="@../css/comunicacionStyles.css">

    <content>
        <VBox alignment="TOP_CENTER"
              fillWidth="true"
              maxWidth="1.7976931348623157E308"
              minHeight="-Infinity"
              spacing="16.0"
              styleClass="module-content">

            <padding>
                <Insets top="32.0"
                        right="32.0"
                        bottom="40.0"
                        left="32.0"/>
            </padding>

            <children>

                <!-- ENCABEZADO -->
                <VBox alignment="CENTER"
                      maxWidth="960.0"
                      spacing="4.0">

                    <children>
                        <Label styleClass="module-title"
                               text="Enviar mensaje"/>

                        <Label maxWidth="760.0"
                               styleClass="module-subtitle"
                               text="Envíe comunicaciones institucionales a residentes y trabajadores del condominio."
                               textAlignment="CENTER"
                               wrapText="true"/>
                    </children>
                </VBox>

                <!-- TARJETA 1: INFORMACIÓN DEL MENSAJE -->
                <VBox maxWidth="960.0"
                      spacing="16.0"
                      styleClass="module-card">

                    <padding>
                        <Insets top="24.0"
                                right="24.0"
                                bottom="24.0"
                                left="24.0"/>
                    </padding>

                    <children>
                        <Label styleClass="module-section-title"
                               text="Información del mensaje"/>

                        <GridPane maxWidth="1.7976931348623157E308"
                                  hgap="16.0"
                                  vgap="14.0">

                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES"
                                                   minWidth="220.0"
                                                   percentWidth="50.0"/>

                                <ColumnConstraints hgrow="SOMETIMES"
                                                   minWidth="220.0"
                                                   percentWidth="50.0"/>
                            </columnConstraints>

                            <rowConstraints>
                                <RowConstraints valignment="TOP"/>
                                <RowConstraints valignment="TOP"/>
                            </rowConstraints>

                            <children>

                                <!-- TIPO -->
                                <VBox spacing="6.0"
                                      GridPane.columnIndex="0"
                                      GridPane.rowIndex="0">

                                    <children>
                                        <Label styleClass="form-label"
                                               text="Tipo de mensaje"/>

                                        <ComboBox fx:id="cmbTipoMensaje"
                                                  maxWidth="1.7976931348623157E308"
                                                  promptText="Seleccione el tipo de comunicación"/>
                                    </children>
                                </VBox>

                                <!-- PRIORIDAD -->
                                <VBox spacing="6.0"
                                      GridPane.columnIndex="1"
                                      GridPane.rowIndex="0">

                                    <children>
                                        <Label styleClass="form-label"
                                               text="Prioridad"/>

                                        <ComboBox fx:id="cmbPrioridad"
                                                  maxWidth="1.7976931348623157E308"
                                                  promptText="Seleccione la prioridad"/>
                                    </children>
                                </VBox>

                                <!-- DESTINATARIOS -->
                                <VBox spacing="6.0"
                                      GridPane.columnIndex="0"
                                      GridPane.columnSpan="2"
                                      GridPane.rowIndex="1">

                                    <children>
                                        <HBox alignment="CENTER_LEFT"
                                              spacing="8.0"
                                              styleClass="recipient-info">

                                            <padding>
                                                <Insets top="9.0"
                                                        right="12.0"
                                                        bottom="9.0"
                                                        left="12.0"/>
                                            </padding>

                                            <children>
                                                <Label styleClass="recipient-info-icon"
                                                       text="i"/>

                                                <Label fx:id="lblDestinatarios"
                                                       maxWidth="1.7976931348623157E308"
                                                       styleClass="recipient-info-text"
                                                       text="Destinatarios: seleccione un tipo de mensaje."
                                                       wrapText="true"
                                                       HBox.hgrow="ALWAYS"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                            </children>
                        </GridPane>

                        <!-- ASUNTO -->
                        <VBox spacing="6.0">

                            <children>
                                <HBox alignment="CENTER_LEFT">

                                    <children>
                                        <Label styleClass="form-label"
                                               text="Asunto"/>

                                        <Region HBox.hgrow="ALWAYS"/>

                                        <Label fx:id="lblContadorAsunto"
                                               styleClass="character-counter"
                                               text="0 / 120"/>
                                    </children>
                                </HBox>

                                <TextField fx:id="txtAsunto"
                                           maxWidth="1.7976931348623157E308"
                                           promptText="Escriba un asunto claro y descriptivo"/>
                            </children>
                        </VBox>

                    </children>
                </VBox>

                <!-- TARJETA 2: CONTENIDO -->
                <VBox maxWidth="960.0"
                      spacing="12.0"
                      styleClass="module-card">

                    <padding>
                        <Insets top="24.0"
                                right="24.0"
                                bottom="24.0"
                                left="24.0"/>
                    </padding>

                    <children>
                        <HBox alignment="CENTER_LEFT">

                            <children>
                                <Label styleClass="module-section-title"
                                       text="Contenido"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Label fx:id="lblContadorCaracteres"
                                       styleClass="character-counter"
                                       text="0 / 2000"/>
                            </children>
                        </HBox>

                        <TextArea fx:id="txtContenido"
                                  maxWidth="1.7976931348623157E308"
                                  minHeight="180.0"
                                  prefHeight="180.0"
                                  promptText="Redacte aquí el contenido completo de la comunicación institucional..."
                                  wrapText="true"/>

                        <Label styleClass="form-hint"
                               text="Use un lenguaje claro, respetuoso y apropiado para los destinatarios seleccionados."
                               wrapText="true"/>
                    </children>
                </VBox>

                <!-- TARJETA 3: ACCIONES -->
                <VBox maxWidth="960.0"
                      spacing="14.0"
                      styleClass="module-card">

                    <padding>
                        <Insets top="20.0"
                                right="24.0"
                                bottom="20.0"
                                left="24.0"/>
                    </padding>

                    <children>
                        <Label fx:id="lblMensaje"
                               maxWidth="1.7976931348623157E308"
                               minHeight="18.0"
                               styleClass="message-label"
                               text=""
                               wrapText="true"/>

                        <HBox alignment="CENTER_RIGHT"
                              spacing="12.0">

                            <children>
                                <Button fx:id="btnCancelar"
                                        mnemonicParsing="false"
                                        onAction="#cancelar"
                                        styleClass="secondary-button"
                                        text="Cancelar"/>

                                <Button fx:id="btnLimpiar"
                                        mnemonicParsing="false"
                                        onAction="#limpiarFormulario"
                                        styleClass="secondary-button"
                                        text="Limpiar"/>

                                <Button fx:id="btnEnviar"
                                        defaultButton="true"
                                        mnemonicParsing="false"
                                        onAction="#enviarMensaje"
                                        styleClass="primary-button"
                                        text="Enviar mensaje"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- TARJETA 4: HISTORIAL RECIENTE -->
                <VBox maxWidth="960.0"
                      minHeight="370.0"
                      spacing="10.0"
                      styleClass="table-card">

                    <padding>
                        <Insets top="16.0"
                                right="16.0"
                                bottom="16.0"
                                left="16.0"/>
                    </padding>

                    <children>
                        <VBox spacing="3.0">

                            <children>
                                <Label styleClass="module-section-title"
                                       text="Historial reciente"/>

                                <Label styleClass="table-subtitle"
                                       text="Últimas comunicaciones gestionadas desde este módulo."
                                       wrapText="true"/>
                            </children>
                        </VBox>

                        <TableView fx:id="tblMensajesRecientes"
                                   maxWidth="1.7976931348623157E308"
                                   minHeight="300.0"
                                   prefHeight="300.0"
                                   onMouseClicked="#seleccionarMensaje"
                                   VBox.vgrow="ALWAYS">

                            <columns>
                                <TableColumn fx:id="colFecha"
                                             minWidth="125.0"
                                             prefWidth="145.0"
                                             text="Fecha"/>

                                <TableColumn fx:id="colTipo"
                                             minWidth="150.0"
                                             prefWidth="190.0"
                                             text="Tipo"/>

                                <TableColumn fx:id="colPrioridad"
                                             minWidth="90.0"
                                             prefWidth="105.0"
                                             text="Prioridad"/>

                                <TableColumn fx:id="colAsunto"
                                             minWidth="210.0"
                                             prefWidth="300.0"
                                             text="Asunto"/>

                                <TableColumn fx:id="colEstado"
                                             minWidth="95.0"
                                             prefWidth="110.0"
                                             text="Estado"/>
                            </columns>

                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>