<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:controller="fis.dsw.sgc.finanzas.controller.SolicitarPagoEnCuotasController"
      alignment="TOP_CENTER"
      maxHeight="1.7976931348623157E308"
      maxWidth="1.7976931348623157E308"
      prefHeight="600.0"
      prefWidth="900.0"
      spacing="16.0"
      styleClass="module-content"
      stylesheets="@../css/solicitarPagoEnCuotas.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/>
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <FontIcon iconLiteral="fa-calendar" iconSize="20" styleClass="module-title-icon"/>
                <Label styleClass="module-title" text="Solicitar pago en cuotas"/>
            </children>
        </HBox>
        <Label styleClass="module-subtitle"
               text="Difiera una deuda pendiente en varias cuotas mensuales (mínimo 3 y máximo 12 meses)."
               wrapText="true"/>

        <VBox maxWidth="960.0"
              maxHeight="1.7976931348623157E308"
              spacing="16.0"
              VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="14.0" styleClass="module-card" maxWidth="1.7976931348623157E308">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
                    </padding>
                    <children>
                        <GridPane hgap="12.0" vgap="14.0" maxWidth="1.7976931348623157E308">
                            <columnConstraints>
                                <ColumnConstraints minWidth="150.0" prefWidth="160.0"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" prefWidth="400.0"/>
                            </columnConstraints>
                            <children>
                                <Label styleClass="form-label" text="ID deuda a diferir"
                                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="txtIdDeuda" promptText="Ej. DEU-001"
                                           maxWidth="1.7976931348623157E308"
                                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label styleClass="form-label" text="Número de meses"
                                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <TextField fx:id="txtNumeroMeses" promptText="Entre 3 y 11 meses"
                                           maxWidth="1.7976931348623157E308"
                                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            </children>
                        </GridPane>

                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Button fx:id="btnCalcular" mnemonicParsing="false"
                                        onAction="#calcular" styleClass="primary-button"
                                        text="Calcular diferimiento"/>
                                <Button fx:id="btnLimpiar" mnemonicParsing="false"
                                        onAction="#limpiar" styleClass="secondary-button"
                                        text="Limpiar"/>
                            </children>
                        </HBox>

                        <Label fx:id="lblMensaje" styleClass="message-label, message-info" text="" wrapText="true"/>
                    </children>
                </VBox>

                <VBox maxHeight="1.7976931348623157E308"
                      maxWidth="1.7976931348623157E308"
                      spacing="8.0"
                      styleClass="table-card"
                      VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
                    </padding>
                    <children>
                        <Label styleClass="module-section-title" text="Cuotas generadas"/>
                        <TableView fx:id="tablaCuotas"
                                   maxHeight="1.7976931348623157E308"
                                   maxWidth="1.7976931348623157E308"
                                   tableMenuButtonVisible="false"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colCuota" prefWidth="160.0" reorderable="false" text="Cuota"/>
                                <TableColumn fx:id="colFechaMax" prefWidth="180.0" reorderable="false" text="Fecha máx. pago"/>
                                <TableColumn fx:id="colValor" prefWidth="140.0" reorderable="false" text="Valor"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" maxWidth="1.7976931348623157E308">
                    <children>
                        <Button fx:id="btnSolicitar" mnemonicParsing="false"
                                onAction="#solicitar" styleClass="primary-button"
                                text="Solicitar"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
