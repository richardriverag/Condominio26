<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minWidth="-Infinity" prefHeight="489.0" prefWidth="779.0" spacing="10.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fis.dsw.sgc.finanzas.controller.RegistrarPagoExternoController">
    <children>
        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0">
            <children>
                <Label fx:id="lblIconoTitulo" text="Label" />
                <Label styleClass="module-title" text="REGISTRAR UN NUEVO GASTO" />
            </children>
        </HBox>
        <HBox alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <!-- VBox Izquierdo -->
                <VBox alignment="CENTER" prefHeight="193.0" prefWidth="429.0" spacing="15.0">
                    <children>
                        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblIconoFecha" text="Label" />
                                <Label styleClass="form-label" text="FECHA" />
                                <DatePicker fx:id="dpFechaGasto" prefHeight="37.0" prefWidth="274.0" styleClass="text-field" />
                            </children>
                        </HBox>
                        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblIconoMotivo" text="Label" />
                                <Label styleClass="form-label" text="MOTIVO" />
                                <ComboBox fx:id="cmbMotivo" prefHeight="37.0" prefWidth="260.0" styleClass="text-field" />
                            </children>
                        </HBox>
                        <HBox fx:id="opcionesServicioBasico" spacing="20.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblIconoServicioBasico" text="Label" />
                                <Label styleClass="form-label" text="ESCOJA:" />
                                <ComboBox fx:id="cmbServiciosBasicos" prefHeight="37.0" prefWidth="262.0" styleClass="text-field" />
                            </children>
                        </HBox>
                        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblIconoValor" text="Label" />
                                <Label styleClass="form-label" text="VALOR" />
                                <TextField fx:id="txtValor" prefHeight="37.0" prefWidth="273.0" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- VBox Derecho -->
                <VBox alignment="CENTER" prefHeight="193.0" prefWidth="268.0" spacing="20.0">
                    <children>
                        <Label fx:id="lblIconoTipoGasto" text="Label" />
                        <Label styleClass="form-label" text="TIPO GASTO" />
                        <Label fx:id="lblIconoValorDidactico" text="Label" />
                        <Label styleClass="form-label" text="VALOR" />
                    </children>
                </VBox>
            </children>
        </HBox>
        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <Label fx:id="lblIconoDescripcion" styleClass="form-label" text="DESCRIPCIÓN" />
                <TextArea fx:id="cmpDescripcion" prefHeight="114.0" prefWidth="476.0" styleClass="text-field" />
            </children>
        </HBox>
        <Label fx:id="lblMensajeEstado" text="Label" visible="false" />
        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
            <children>
                <Button fx:id="btnGuardar" mnemonicParsing="false" styleClass="primary-button" text="GUARDAR" />
                <Button fx:id="btnLimpiar" mnemonicParsing="false" styleClass="primary-button" text="LIMPIAR" />
            </children></HBox>
    </children>
    <padding>
        <Insets left="10.0" right="10.0" />
    </padding>
    <stylesheets>
        <URL value="@../css/finanzasStyles.css" />
        <URL value="@../css/pagoExternoSyles.css" />
    </stylesheets>
</VBox>
