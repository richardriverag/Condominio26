<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:controller="fis.dsw.sgc.finanzas.controller.RegistrarDeudaController"
      alignment="TOP_CENTER"
      maxHeight="1.7976931348623157E308"
      maxWidth="1.7976931348623157E308"
      prefHeight="600.0"
      prefWidth="900.0"
      spacing="0"
      styleClass="module-content"
      stylesheets="@../css/finanzasStyles.css,@../css/finanzasBryan.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="28.0"/>
    </padding>

    <children>
        <VBox maxWidth="900.0" spacing="14.0" alignment="TOP_CENTER">
            <children>
                <HBox alignment="CENTER" spacing="10.0"
                      maxWidth="1.7976931348623157E308">
                    <children>
                        <FontIcon iconLiteral="fa-plus-circle" iconSize="22" styleClass="module-title-icon"/>
                        <Label styleClass="module-title" text="Registrar deuda"/>
                    </children>
                </HBox>
                <Label styleClass="module-subtitle"
                       wrapText="true"
                       textAlignment="CENTER"
                       maxWidth="1.7976931348623157E308"
                       text="Registre una deuda de alícuota, multa o reserva para un residente."/>

                <VBox spacing="14.0" styleClass="module-card"
                      maxWidth="1.7976931348623157E308">
                    <padding>
                        <Insets bottom="24.0" left="28.0" right="28.0" top="24.0"/>
                    </padding>
                    <children>
                        <GridPane hgap="12.0" vgap="14.0" maxWidth="1.7976931348623157E308">
                            <columnConstraints>
                                <ColumnConstraints minWidth="160.0" prefWidth="170.0"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="220.0" prefWidth="480.0"/>
                            </columnConstraints>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <FontIcon iconLiteral="fa-id-card" iconSize="14" styleClass="field-icon"/>
                                        <Label styleClass="form-label" text="Cédula residente"/>
                                    </children>
                                </HBox>
                                <TextField fx:id="txtCedula" promptText="Número de cédula"
                                           maxWidth="1.7976931348623157E308"
                                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <HBox alignment="CENTER_LEFT" spacing="8.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <children>
                                        <FontIcon iconLiteral="fa-tags" iconSize="14" styleClass="field-icon"/>
                                        <Label styleClass="form-label" text="Motivo"/>
                                    </children>
                                </HBox>
                                <ComboBox fx:id="cmbMotivo" maxWidth="1.7976931348623157E308"
                                          GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <HBox alignment="CENTER_LEFT" spacing="8.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <children>
                                        <FontIcon iconLiteral="fa-calendar" iconSize="14" styleClass="field-icon"/>
                                        <Label styleClass="form-label" text="Fecha máx. pago"/>
                                    </children>
                                </HBox>
                                <DatePicker fx:id="dpFechaMax" maxWidth="1.7976931348623157E308"
                                            GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <HBox alignment="CENTER_LEFT" spacing="8.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="3">
                                    <children>
                                        <FontIcon iconLiteral="fa-money" iconSize="14" styleClass="field-icon"/>
                                        <Label styleClass="form-label" text="Valor"/>
                                    </children>
                                </HBox>
                                <TextField fx:id="txtValor" promptText="0.00"
                                           maxWidth="1.7976931348623157E308"
                                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                <HBox alignment="CENTER_LEFT" spacing="8.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="4">
                                    <children>
                                        <FontIcon iconLiteral="fa-align-left" iconSize="14" styleClass="field-icon"/>
                                        <Label styleClass="form-label" text="Descripción"/>
                                    </children>
                                </HBox>
                                <TextArea fx:id="txtDescripcion" prefRowCount="3" wrapText="true"
                                          promptText="Descripción de la deuda"
                                          maxWidth="1.7976931348623157E308"
                                          GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                            </children>
                        </GridPane>

                        <HBox alignment="CENTER" spacing="12.0">
                            <children>
                                <Button onAction="#registrar" styleClass="primary-button" text="Registrar deuda"/>
                                <Button onAction="#limpiar" styleClass="secondary-button" text="Limpiar"/>
                            </children>
                        </HBox>

                        <Label fx:id="lblMensaje" styleClass="message-label, message-info"
                               wrapText="true" textAlignment="CENTER"
                               maxWidth="1.7976931348623157E308" text=""/>
                    </children>
                </VBox>
            </children>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
    </children>
</VBox>
