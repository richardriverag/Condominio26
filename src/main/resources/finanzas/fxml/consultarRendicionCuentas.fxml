<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="fis.dsw.sgc.finanzas.controller.ConsultarRendicionCuentasController"
      alignment="TOP_CENTER"
      maxHeight="1.7976931348623157E308"
      maxWidth="1.7976931348623157E308"
      prefHeight="600.0"
      prefWidth="900.0"
      spacing="16.0"
      styleClass="module-content"
      stylesheets="@../css/finanzasStyles.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0"/>
    </padding>

    <children>
        <Label styleClass="module-title" text="Consultar rendición de cuentas"/>
        <Label styleClass="module-subtitle"
               text="Seleccione el periodo para consultar el reporte de la rendición de cuentas."/>

        <VBox maxWidth="960.0"
              maxHeight="1.7976931348623157E308"
              spacing="16.0"
              VBox.vgrow="ALWAYS">
            <children>
                <!-- Tarjeta Superior: Filtros de Fecha -->
                <VBox spacing="14.0" styleClass="module-card" maxWidth="1.7976931348623157E308">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
                    </padding>
                    <children>
                        <GridPane hgap="12.0" vgap="14.0" maxWidth="1.7976931348623157E308">
                            <columnConstraints>
                                <ColumnConstraints minWidth="130.0" prefWidth="140.0"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" prefWidth="400.0"/>
                            </columnConstraints>
                            <children>
                                <Label styleClass="form-label" text="Fecha inicio" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <DatePicker fx:id="dpInicio" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label styleClass="form-label" text="Fecha fin" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <DatePicker fx:id="dpFin" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            </children>
                        </GridPane>

                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#consultar" styleClass="primary-button" text="Consultar"/>
                                <Button mnemonicParsing="false" onAction="#limpiar" styleClass="secondary-button" text="Limpiar"/>
                            </children>
                        </HBox>

                        <Label fx:id="lblMensaje" styleClass="message-label, message-info" text=""/>
                    </children>
                </VBox>

                <!-- Tarjeta Inferior: Tabla de Resultados -->
                <VBox maxHeight="1.7976931348623157E308"
                      maxWidth="1.7976931348623157E308"
                      spacing="8.0"
                      styleClass="table-card"
                      VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
                    </padding>
                    <children>
                        <Label styleClass="module-section-title" text="Resultados"/>
                        <TableView fx:id="tablaResultados"
                                   maxHeight="1.7976931348623157E308"
                                   maxWidth="1.7976931348623157E308"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colMotivo" prefWidth="140.0" text="Motivo"/>
                                <TableColumn fx:id="colValor" prefWidth="100.0" text="Valor"/>
                                <TableColumn fx:id="colFecha" prefWidth="150.0" text="Fecha máx. pago"/>
                                <TableColumn fx:id="colEstado" prefWidth="120.0" text="Estado"/>
                                <TableColumn fx:id="colDescripcion" prefWidth="280.0" text="Descripción"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <HBox fx:id="boxImprimir" alignment="CENTER" spacing="20.0" visible="false" managed="false">
                    <children>
                        <Label fx:id="lblIconoImprimir" text="Label" />
                        <Button fx:id="btnImprimir" mnemonicParsing="false" onAction="#imprimirReporte" styleClass="primary-button" text="DESCARGAR" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>