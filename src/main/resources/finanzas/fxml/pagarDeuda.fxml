<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox
      alignment="TOP_CENTER"
      maxHeight="1.7976931348623157E308"
      maxWidth="1.7976931348623157E308"
      prefHeight="600.0"
      prefWidth="900.0"
      spacing="0"
      styleClass="module-content"
      stylesheets="@../css/finanzasStyles.css,@../css/finanzasBryan.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="28.0"/>
    </padding>

    <children>
        <VBox maxWidth="900.0"
              maxHeight="1.7976931348623157E308"
              spacing="14.0"
              alignment="TOP_CENTER">
            <children>
                <HBox alignment="CENTER" spacing="10.0"
                      maxWidth="1.7976931348623157E308">
                    <children>
                        <FontIcon iconLiteral="fa-credit-card" iconSize="22" styleClass="module-title-icon"/>
                        <Label styleClass="module-title" text="Pagar deuda"/>
                    </children>
                </HBox>
                <Label styleClass="module-subtitle"
                       wrapText="true"
                       textAlignment="CENTER"
                       maxWidth="1.7976931348623157E308"
                       text="Ingrese el ID de la deuda, revise el valor y elija el método de pago."/>

                <VBox spacing="14.0" styleClass="module-card"
                      maxWidth="1.7976931348623157E308">
                    <padding>
                        <Insets bottom="24.0" left="28.0" right="28.0" top="24.0"/>
                    </padding>
                    <children>
                        <GridPane hgap="12.0" vgap="14.0"
                                  maxWidth="1.7976931348623157E308">
                            <columnConstraints>
                                <ColumnConstraints minWidth="160.0" prefWidth="170.0"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="220.0" prefWidth="480.0"/>
                            </columnConstraints>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <FontIcon iconLiteral="fa-hashtag" iconSize="14" styleClass="field-icon"/>
                                        <Label styleClass="form-label" text="ID deuda"/>
                                    </children>
                                </HBox>
                                <TextField fx:id="txtIdDeuda" promptText="Ej. DEU-001"
                                           maxWidth="1.7976931348623157E308"
                                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <HBox alignment="CENTER_LEFT" spacing="8.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <children>
                                        <FontIcon iconLiteral="fa-money" iconSize="14" styleClass="field-icon"/>
                                        <Label styleClass="form-label" text="Valor"/>
                                    </children>
                                </HBox>
                                <Label fx:id="lblValor" styleClass="form-value" text="(consulte la deuda)"
                                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <HBox alignment="CENTER_LEFT" spacing="8.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <children>
                                        <FontIcon iconLiteral="fa-info-circle" iconSize="14" styleClass="field-icon"/>
                                        <Label styleClass="form-label" text="Estado"/>
                                    </children>
                                </HBox>
                                <Label fx:id="lblEstado" styleClass="form-value" text="(consulte la deuda)"
                                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <HBox alignment="CENTER_LEFT" spacing="8.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="3">
                                    <children>
                                        <FontIcon iconLiteral="fa-exchange" iconSize="14" styleClass="field-icon"/>
                                        <Label styleClass="form-label" text="Método de pago"/>
                                    </children>
                                </HBox>
                                <ComboBox fx:id="cmbMetodo" maxWidth="1.7976931348623157E308"
                                          GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                <HBox alignment="CENTER_LEFT" spacing="8.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="4">
                                    <children>
                                        <FontIcon iconLiteral="fa-university" iconSize="14" styleClass="field-icon"/>
                                        <Label styleClass="form-label" text="Datos bancarios"/>
                                    </children>
                                </HBox>
                                <Label fx:id="lblDatosBancarios" styleClass="module-subtitle"
                                       text="Se muestran si elige transferencia."
                                       wrapText="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                                <HBox alignment="CENTER_LEFT" spacing="8.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="5">
                                    <children>
                                        <FontIcon iconLiteral="fa-file-text-o" iconSize="14" styleClass="field-icon"/>
                                        <Label styleClass="form-label" text="Comprobante"/>
                                    </children>
                                </HBox>
                                <TextField fx:id="txtComprobante"
                                           promptText="Solo para transferencia"
                                           maxWidth="1.7976931348623157E308"
                                           GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                            </children>
                        </GridPane>

                        <HBox alignment="CENTER" spacing="12.0">
                            <children>
                                <Button fx:id="btnConsultar" mnemonicParsing="false"
                                        onAction="#consultarDeuda" styleClass="secondary-button"
                                        text="Consultar deuda"/>
                                <Button fx:id="btnPagar" mnemonicParsing="false"
                                        onAction="#pagar" styleClass="primary-button"
                                        text="Pagar"/>
                                <Button fx:id="btnLimpiar" mnemonicParsing="false"
                                        onAction="#limpiar" styleClass="secondary-button"
                                        text="Limpiar"/>
                            </children>
                        </HBox>

                        <Label fx:id="lblMensaje" styleClass="message-label, message-info"
                               wrapText="true" textAlignment="CENTER"
                               maxWidth="1.7976931348623157E308" text=""/>
                    </children>
                </VBox>
            </children>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
    </children>
</VBox>
