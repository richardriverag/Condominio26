' ==========================================
' MÓDULO GRF: COMUNICACIONES
' ==========================================
package "GRF - Comunicaciones" {

    enum TipoComunicacion {
        MENSAJE_RESIDENTES
        COMUNICADO_TRABAJADORES
        MENSAJE_GLOBAL
        ANUNCIO_GENERAL
        MENSAJE_URGENTE
        ALERTA_EMERGENCIA
        BOLETIN_INFORMATIVO
    }

    enum EstadoComunicacion {
        CREADA
        ENVIADA
        FALLIDA
        ELIMINADA
    }

    class Mensaje {
        - idMensaje: Long
        - asunto: String
        - contenido: String
        - tipo: TipoComunicacion
        - prioridad: String
        - fechaCreacion: Date
        - fechaEnvio: Date
        - estado: EstadoComunicacion
        + validarContenido(): boolean
        + enviar(): void
        + marcarComoEnviado(): void
    }

    class MensajeDestinatario {
        - leido: boolean
        - fechaLectura: Date
        + marcarComoLeido(): void
        + estaLeido(): boolean
    }

    class Anuncio {
        - idAnuncio: Long
        - titulo: String
        - contenido: String
        - tipo: TipoComunicacion
        - prioridad: String
        - fechaPublicacion: Date
        - fechaExpiracion: Date
        - estado: EstadoComunicacion
        + validarContenido(): boolean
        + publicar(): void
        + verificarVigencia(): boolean
    }

    class Notificacion {
        - idNotificacion: Long
        - tipo: String
        - asunto: String
        - fechaEnvio: Date
        - leida: boolean
        + generar(): void
        + marcarComoLeida(): void
        + eliminar(): void
    }

    class HistorialComunicacion {
        - idHistorial: Long
        - tipo: String
        - asunto: String
        - estado: String
        - detalle: String
        - fechaRegistro: Date
        + registrarAccion(): void
    }

    class ReporteComunicacion {
        - fechaInicio: Date
        - fechaFin: Date
        - totalComunicaciones: int
        - totalEnviadas: int
        - totalFallidas: int
        - tasaExito: double
        + generarResumen(): void
        + calcularTasaExito(): double
    }

    interface IComunicacionStrategy <<Strategy>> {
        + soporta(tipo: String): boolean
        + validar(mensaje: Mensaje): void
    }

    class ComunicacionSegmentadaStrategy implements IComunicacionStrategy
    class ComunicacionGlobalStrategy implements IComunicacionStrategy
    class ComunicacionUrgenteStrategy implements IComunicacionStrategy

    class ComunicacionStrategyResolver {
        - estrategias: List<IComunicacionStrategy>
        + obtener(tipo: String): IComunicacionStrategy
    }

    Mensaje "*" --> "1" Usuario : enviado por
    Anuncio "*" --> "1" Usuario : publicado por
    Notificacion "*" --> "1" Usuario : pertenece a

    Mensaje "1" *-- "1..*" MensajeDestinatario : posee
    MensajeDestinatario "*" --> "1" Usuario : corresponde a

    Mensaje "1" --> "0..*" Notificacion : genera
    Anuncio "1" --> "0..*" Notificacion : genera

    Mensaje "1" --> "0..*" HistorialComunicacion : registra
    Anuncio "1" --> "0..*" HistorialComunicacion : registra

    ReporteComunicacion --> HistorialComunicacion : consulta



    ComunicacionStrategyResolver "1" o-- "1..*" IComunicacionStrategy : administra
}