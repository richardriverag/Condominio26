@startuml ClassDiagramMVC

skinparam style strictuml
skinparam packageStyle rect
skinparam linetype ortho
skinparam classAttributeIconSize 0

title Diseño Arquitectónico (MVC + Patrones) - Módulo GRC

'==================================================
' CONTROLADORES
'==================================================

package "Controladores (JavaFX)"{

class VistaGestionPropiedades{
+mostrarFormulario()
}

class VistaCatalogo{
+mostrarCatalogo()
}

class VistaCasosFortuitos{
+mostrarCasos()
}

class ControladorPropiedades{
-servicio:IGestionInmueblesAPI
+registrarInmueble()
+actualizarEstado()
}

class ControladorCatalogo{
-servicio:IGestionInmueblesAPI
+consultarCatalogo()
}

class ControladorCasos{
-servicio:IGestionInmueblesAPI
+registrarCaso()
}

VistaGestionPropiedades ..> ControladorPropiedades
VistaCatalogo ..> ControladorCatalogo
VistaCasosFortuitos ..> ControladorCasos

}

'==================================================
' FACHADA
'==================================================

package "Fachada del módulo"{

interface IGestionInmueblesAPI <<Facade>>{

+consultarPropiedades()

+consultarCatalogo()

+consultarReporteCambios()

+registrarCasoFortuito()

}

}

'==================================================
' SERVICIOS
'==================================================

package "Servicios (Logica de Casos de Uso)"{

class ServicioGestionInmuebles{

-inmuebleDAO:InmuebleDAO

-reporteDAO:ReporteCambioDAO

+registrar()

+actualizarEstado()

}

class ServicioCatalogo{

-inmuebleDAO:InmuebleDAO

+consultarCatalogo()

}

class ServicioCasos{

-casoDAO:CasoFortuitoDAO

+registrarCaso()

}

class ServicioReportes{

-reporteDAO:ReporteCambioDAO

+registrarCambio()

}

}

'==================================================
' DAO
'==================================================

package "Repositorios DAO"{

interface InmuebleDAO{

+guardar()

+actualizar()

+buscar()

}

interface CasoFortuitoDAO{

+guardar()

+listar()

}

interface ReporteCambioDAO{

+guardar()

+listar()

}

class InmuebleDAOImpl
class CasoFortuitoDAOImpl
class ReporteCambioDAOImpl

InmuebleDAO <|.. InmuebleDAOImpl
CasoFortuitoDAO <|.. CasoFortuitoDAOImpl
ReporteCambioDAO <|.. ReporteCambioDAOImpl

}

'==================================================
' PATRONES DE DISEÑO
'==================================================

package "Patrones de Diseño"{

interface InmuebleFactory <<Factory>>{

+crearDepartamento()

+crearSuite()

+crearSalonEventos()

+crearAreaRecreacional()

+crearParqueadero()

}

class InmuebleFactoryImpl

InmuebleFactory <|.. InmuebleFactoryImpl


interface IteratorInmueble <<Iterator>>{

+hasNext()

+next()

}

class CatalogoIterator

IteratorInmueble <|.. CatalogoIterator


class GestorPlazas <<Singleton>>{

-instance

+getInstance()

+asignarPlaza()

+liberarPlaza()

}

}

'==================================================
' ENTIDADES DEL DOMINIO
'==================================================

package "Dominio"{


' ==========================================
' CLASE ABSTRACTA PADRE (INMUEBLE)
' ==========================================
abstract class Inmueble {
   
}

enum EstadoInmueble {
    
}

' ==========================================
' CLASES HIJAS (Jerarquía de Inmueble)
' ==========================================
class Departamento {
   
}

class Suite {
    
}

abstract class EspacioComun {
    
}

class SalonDeEventos {
 
}

class AreaRecreacional {
    
}

class Parqueadero {
    
}

' ==========================================
' PLAZAS
' ==========================================
abstract class Plaza {
    
}

class PlazaPropietario {

}

class PlazaVisita {
   
}

' ==========================================
' HERENCIAS
' ==========================================
Inmueble <|-- Departamento
Inmueble <|-- Suite
Inmueble <|-- EspacioComun
Inmueble <|-- Parqueadero

EspacioComun <|-- SalonDeEventos
EspacioComun <|-- AreaRecreacional

Plaza <|-- PlazaPropietario
Plaza <|-- PlazaVisita

' ==========================================
' COMPOSICIÓN
' ==========================================
Parqueadero "1" *-- "0..*" Plaza : "contiene"

' ==========================================
' COMPONENTES Y GESTIÓN
' ==========================================
class CatalogoCondominio{
    

}

class ReporteCambio {
   
}

class Propiedad {
    
}

class CasoFortuito {
    
}

enum EstadoCaso {
  
}


'==================================================
' ENTIDAD PARCIAL (GRB)
'==================================================

package "Módulo Externo GRB" {

class Usuario <<Partial>>{
-idUsuario:String
-nombre:String
}

}

' ==========================================
' DEPENDENCIAS CON ENUMS (ESTILO GRD/GRE/GRF)
' ==========================================
Inmueble .down.> EstadoInmueble : <<use>>
CasoFortuito .down.> EstadoCaso : <<use>>

' ==========================================
' DISPOSICIÓN DE RELACIONES
' ==========================================
CatalogoCondominio "1" o-right- "*" Inmueble
Inmueble "1" --> "*" ReporteCambio
Inmueble "1" --> "*" CasoFortuito : "registra"

Propiedad "*" --> "1" Inmueble : "asociada a"
Propiedad "*" --> "1" Usuario : "pertenece a (Propietario)"
PlazaPropietario "*" --> "1" Propiedad : "asignada a"

}


'==================================================
' FLUJO MVC
'==================================================

ControladorPropiedades --> IGestionInmueblesAPI
ControladorCatalogo --> IGestionInmueblesAPI
ControladorCasos --> IGestionInmueblesAPI

IGestionInmueblesAPI --> ServicioGestionInmuebles
IGestionInmueblesAPI --> ServicioCatalogo
IGestionInmueblesAPI --> ServicioCasos
IGestionInmueblesAPI --> ServicioReportes

ServicioGestionInmuebles --> InmuebleDAO
ServicioCatalogo --> InmuebleDAO
ServicioCasos --> CasoFortuitoDAO
ServicioReportes --> ReporteCambioDAO

'==================================================
' DEPENDENCIAS HACIA EL DOMINIO
'==================================================

ServicioGestionInmuebles ..> Inmueble
ServicioGestionInmuebles ..> Propiedad

ServicioCatalogo ..> CatalogoCondominio

ServicioCasos ..> CasoFortuito

ServicioReportes ..> ReporteCambio

'==================================================
' DEPENDENCIAS CON LOS PATRONES
'==================================================

ServicioGestionInmuebles ..> InmuebleFactory : crea

CatalogoCondominio ..> IteratorInmueble : createIterator()

InmuebleFactoryImpl ..> Departamento
InmuebleFactoryImpl ..> Suite
InmuebleFactoryImpl ..> SalonDeEventos
InmuebleFactoryImpl ..> AreaRecreacional
InmuebleFactoryImpl ..> Parqueadero

GestorPlazas ..> Parqueadero
GestorPlazas ..> Plaza

@enduml
