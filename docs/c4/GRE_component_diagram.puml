@startuml C4_Component_Diagram_GRE

!include ../libs/c4/C4_Component.puml

LAYOUT_TOP_DOWN()
LAYOUT_WITH_LEGEND()

title Diagrama de Componentes - Módulo GRE: Check-in

skinparam defaultFontName Arial
skinparam shadowing false
skinparam linetype ortho

skinparam nodesep 130
skinparam ranksep 160
skinparam wrapWidth 220
skinparam maxMessageSize 160

skinparam ArrowFontSize 10
skinparam ArrowThickness 1
skinparam Padding 8

Person(presidente, "Presidente", "Supervisa la administración del condominio.")
Person(residente, "Residente", "Realiza pagos, reservas y recibe notificaciones.")
Person(security, "Personal de Seguridad", "Gestiona visitas\ny controla accesos.")

Lay_R(presidente, security)
Lay_R(security, residente)

System_Boundary(sistema, "Sistema de Gestión de Condominio") {

    Container_Boundary(appEscritorio, "Aplicación de Escritorio", "JavaFX") {

        Boundary(moduloCheckIn, "Módulo GRE") {

            Component(vistaPresidente, "Vista Presidente", "JavaFX", "Interfaz para consultar historial de entradas y enviar alertas del condominio.")
            Component(vistaResidente, "Vista Residente", "JavaFX", "Interfaz para programar visitas y consultar notificaciones relacionadas.")
            Component(vistaSeguridad, "Vista Seguridad", "JavaFX", "Interfaz para registrar entradas, controlar accesos y gestionar parqueaderos de visita.")

            Component(controladorEntradas, "Controlador de Entradas", "Java Controller", "Recibe solicitudes de registro de entradas de residentes, visitantes y personas externas.")
            Component(controladorVisitas, "Controlador de Visitas", "Java Controller", "Gestiona las solicitudes relacionadas con la programación de visitas.")
            Component(controladorParqueadero, "Controlador de Parqueaderos", "Java Controller", "Coordina las solicitudes de asignación y registro de parqueaderos de visita.")
            Component(controladorAlertas, "Controlador de Alertas", "Java Controller", "Gestiona las solicitudes para enviar alertas rápidas.")
            Component(controladorHistorial, "Controlador de Historial", "Java Controller", "Procesa las solicitudes de consulta del historial de entradas.")

            Component(servicioEntradas, "Servicio de Registro de Entradas", "Java Service", "Registra entradas de residentes, visitantes y personas externas.")
            Component(servicioVisitas, "Servicio de Programación de Visitas", "Java Service", "Permite registrar visitas programadas por los residentes.")
            Component(servicioParqueadero, "Servicio de Parqueaderos", "Java Service", "Coordina y registra el uso de parqueaderos de visita.")
            Component(servicioAlertas, "Servicio de Alertas", "Java Service", "Gestiona alertas rápidas en caso de emergencia o simulacro.")
            Component(servicioHistorial, "Servicio de Historial Entrada", "Java Service", "Consulta y gestiona el historial de entradas.")
            Component(servicioNotificaciones, "Servicio de Notificaciones", "Java Service", "Prepara notificaciones de entradas, visitas programadas y alertas.")

            Component(repositorioCheckIn, "Repositorio Check-in", "DAO / Repository", "Accede a los datos de entradas, visitas, parqueaderos, alertas e historial.")
        }

        Component(moduloUsuarios, "Módulo GRA", "Java / JavaFX", "Valida residentes, presidente, roles y permisos.")

        Component(moduloGRC, "Módulo GRC", "Java / JavaFX", "Gestiona la disponibilidad y uso de parqueaderos y áreas comunes.")

        Component(moduloComunicacion, "Módulo GRF", "Java / JavaFX", "Envía mensajes, notificaciones y alertas.")
    }

    ContainerDb(baseDatos, "Base de Datos", "MySQL", "Almacena visitantes, residentes, entradas, visitas programadas, parqueaderos, alertas e historial.")
}

Rel_D(presidente, vistaPresidente, "Consulta historial\ny envía alertas", "UI")
Rel_D(residente, vistaResidente, "Programa visitas", "UI")
Rel_D(security, vistaSeguridad, "Registra entradas\ny parqueaderos", "UI")

Rel_D(vistaSeguridad, controladorEntradas, "Solicita registrar\nentrada", "Eventos / DTO")
Rel_D(vistaSeguridad, controladorParqueadero, "Solicita asignar\nparqueadero", "Eventos / DTO")

Rel_D(vistaResidente, controladorVisitas, "Solicita programar\nvisita", "Eventos / DTO")

Rel_D(vistaPresidente, controladorHistorial, "Solicita consultar\nhistorial", "Eventos / DTO")
Rel_D(vistaPresidente, controladorAlertas, "Solicita enviar\nalerta", "Eventos / DTO")
Rel_D(vistaPresidente, controladorVisitas, "Solicita consultar\nvisitas programadas", "Eventos / DTO")

Rel_D(controladorEntradas, servicioEntradas, "Coordina registro\nde entradas", "Java")
Rel_D(controladorVisitas, servicioVisitas, "Coordina programación\nde visitas", "Java")
Rel_D(controladorParqueadero, servicioParqueadero, "Coordina uso\nde parqueaderos", "Java")
Rel_D(controladorAlertas, servicioAlertas, "Coordina envío\nde alertas", "Java")
Rel_D(controladorHistorial, servicioHistorial, "Coordina consulta\nde historial", "Java")

Rel_R(servicioEntradas, moduloUsuarios, "Valida persona\nrelacionada", "Java")
Rel_R(servicioVisitas, moduloUsuarios, "Valida residente", "Java")

Rel_R(servicioVisitas, servicioParqueadero, "Solicita asignar\nparqueadero de visita", "Java")
Rel_R(servicioParqueadero, moduloGRC, "Consulta disponibilidad\nde parqueaderos", "Java")

Rel_R(servicioEntradas, servicioNotificaciones, "Solicita notificar\nentrada", "Java")
Rel_R(servicioVisitas, servicioNotificaciones, "Solicita notificar\nvisita", "Java")
Rel_R(servicioAlertas, servicioNotificaciones, "Solicita enviar\nalerta", "Java")

Rel_R(servicioNotificaciones, moduloComunicacion, "Envía\nnotificaciones", "Java")

Rel_D(servicioEntradas, repositorioCheckIn, "Guarda\nentradas", "SQL")
Rel_D(servicioVisitas, repositorioCheckIn, "Guarda visitas\nprogramadas", "SQL")
Rel_D(servicioParqueadero, repositorioCheckIn, "Guarda\nparqueaderos", "SQL")
Rel_D(servicioHistorial, repositorioCheckIn, "Consulta\nhistorial", "SQL")

Rel_D(repositorioCheckIn, baseDatos, "Lee y escribe\ndatos", "JDBC / SQL")

Lay_D(vistaPresidente, controladorHistorial)
Lay_D(vistaSeguridad, controladorEntradas)
Lay_D(vistaResidente, controladorVisitas)

Lay_D(controladorEntradas, servicioEntradas)
Lay_D(controladorVisitas, servicioVisitas)
Lay_D(controladorParqueadero, servicioParqueadero)
Lay_D(controladorAlertas, servicioAlertas)
Lay_D(controladorHistorial, servicioHistorial)

Lay_D(servicioEntradas, repositorioCheckIn)
Lay_D(repositorioCheckIn, baseDatos)

Lay_R(vistaPresidente, vistaSeguridad)
Lay_R(vistaSeguridad, vistaResidente)

Lay_R(controladorEntradas, controladorVisitas)
Lay_R(controladorVisitas, controladorParqueadero)
Lay_R(controladorParqueadero, controladorAlertas)
Lay_R(controladorAlertas, controladorHistorial)

Lay_R(servicioEntradas, servicioVisitas)
Lay_R(servicioVisitas, servicioParqueadero)
Lay_R(servicioParqueadero, servicioAlertas)
Lay_R(servicioAlertas, servicioHistorial)

@enduml